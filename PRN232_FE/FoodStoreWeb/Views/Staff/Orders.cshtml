@{
    ViewData["Title"] = "Đơn Hàng Mới";
}
<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="display-6 fw-bold mb-2">
                    <i class="fas fa-clipboard-list me-3"></i>
                    Đơn Hàng Mới
                </h1>
                <p class="lead mb-0 opacity-75">Quản lý và xử lý đơn hàng</p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <button class="btn btn-light btn-lg" onclick="filterOrders()">
                    <i class="fas fa-sync-alt me-2"></i>
                    Làm mới
                </button>
            </div>
        </div>
    </div>
</section>

<div class="container">
    <!-- Statistics Cards -->
    <div class="row g-4 mb-4" id="statsSection">
        <div class="col-md-3">
            <div class="card stats-card h-100">
                <div class="card-body text-center">
                    <div class="stats-icon bg-warning bg-opacity-10 text-warning">
                        <i class="fas fa-clock"></i>
                    </div>
                    <h3 class="card-title" id="pendingCount">0</h3>
                    <p class="card-text text-muted">Đơn hàng chờ</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stats-card h-100">
                <div class="card-body text-center">
                    <div class="stats-icon bg-danger bg-opacity-10 text-danger">
                        <i class="fas fa-exclamation-triangle notification-bell"></i>
                    </div>
                    <h3 class="card-title" id="urgentCount">0</h3>
                    <p class="card-text text-muted">Cần xử lý gấp</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stats-card h-100">
                <div class="card-body text-center">
                    <div class="stats-icon bg-primary bg-opacity-10 text-primary">
                        <i class="fas fa-calendar-day"></i>
                    </div>
                    <h3 class="card-title" id="todayCount">0</h3>
                    <p class="card-text text-muted">Hôm nay</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stats-card h-100">
                <div class="card-body text-center">
                    <div class="stats-icon bg-success bg-opacity-10 text-success">
                        <i class="fas fa-dollar-sign"></i>
                    </div>
                    <h3 class="card-title" id="totalAmount">0đ</h3>
                    <p class="card-text text-muted">Tổng giá trị</p>
                </div>
            </div>
        </div>
    </div>


    <!-- Orders Section -->
    <div id="ordersContainer">
        <!-- Filter Section -->
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
            <div>
                <h4 class="mb-1">Danh sách đơn hàng</h4>
                <small class="text-muted">Nhấn vào đơn hàng để xem chi tiết</small>
                <p class="text-muted">
                    <span id="ordersCountText">Tổng cộng: 0 đơn hàng</span>
                </p>
            </div>
            <div class="mt-3 mt-md-0">
                <div class="btn-group" role="group" aria-label="Bộ lọc trạng thái">
                    <input type="radio" class="btn-check" name="statusFilter" id="all" checked>
                    <label class="btn btn-outline-primary" for="all">
                        <i class="fas fa-list me-1"></i> Tất cả
                    </label>

                    <input type="radio" class="btn-check" name="statusFilter" id="pending">
                    <label class="btn btn-outline-warning" for="pending">
                        <i class="fas fa-clock me-1"></i> Chờ xử lý
                    </label>

                    <input type="radio" class="btn-check" name="statusFilter" id="urgent">
                    <label class="btn btn-outline-danger" for="urgent">
                        <i class="fas fa-exclamation-triangle me-1"></i> Cần gấp
                    </label>
                </div>
            </div>
        </div>
        <!-- Orders List -->
        <div id="ordersListStaff" class="row g-3"></div>
    </div>
    <!-- Loading State -->
    <div id="loadingState" class="text-center py-5">
        <div class="spinner-border loading-spinner text-primary" role="status">
            <span class="visually-hidden">Đang tải...</span>
        </div>
        <p class="mt-3 text-muted">Đang tải đơn hàng...</p>
    </div>

    <!-- Empty State -->
    <div id="emptyState" class="empty-state text-center">
        <div class="empty-icon">
            <i class="fas fa-inbox text-muted"></i>
        </div>
        <h4 class="text-muted">Không có đơn hàng mới</h4>
        <p class="text-muted">Hiện tại không có đơn hàng nào cần xử lý</p>
        <button class="btn btn-primary btn-lg" onclick="filterOrders()">
            <i class="fas fa-sync-alt me-2"></i>
            Kiểm tra lại
        </button>
    </div>
</div>

<!-- Floating Action Button -->
<button class="btn btn-primary fab" onclick="filterOrders()" title="Làm mới danh sách" data-bs-toggle="tooltip">
    <i class="fas fa-sync-alt"></i>
</button>

<!-- Order Detail Modal -->
<div class="modal fade" id="orderDetailModal" tabindex="-1" aria-labelledby="orderDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title" id="orderDetailModalLabel">
                    <i class="fas fa-receipt me-2 text-primary"></i>
                    Chi tiết đơn hàng
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body" id="orderDetailContent">
                <!-- Order details -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i> Đóng
                </button>
                <button type="button" class="btn btn-success" id="acceptOrderBtn" style="display: none;">
                    <i class="fas fa-check me-2"></i>
                    Chấp nhận đơn hàng
                </button>
                <button type="button" class="btn btn-primary" id="completeOrderBtn" style="display: none;">
                    <i class="fas fa-check-double me-2"></i>
                    Hoàn thành đơn hàng
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Success/Error Toast Container -->
<div class="toast-container position-fixed top-0 end-0 p-3">
    <div id="successToast" class="toast align-items-center text-white bg-success border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body">
                <i class="fas fa-check-circle me-2"></i>
                <span id="successMessage"></span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>

    <div id="errorToast" class="toast align-items-center text-white bg-danger border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body">
                <i class="fas fa-exclamation-circle me-2"></i>
                <span id="errorMessage"></span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>

    <div id="urgentToast" class="toast align-items-center text-white bg-warning border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body">
                <i class="fas fa-bell me-2"></i>
                <span id="urgentMessage"></span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>



