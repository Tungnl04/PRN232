<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - FastOrder</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="@Url.Content("~/css/Layout.css")" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
          integrity="sha512-8ycRcgRQ3Rzqu1bMZ8yT9DPYEKkV7kZnOdU5zD4xQ3KDT7XhV4zPRAcKmTdZm3sZ05SGCk6wQOdgLJX+Q8Y0BA=="
          crossorigin="anonymous"
          referrerpolicy="no-referrer" />

</head>
<body>
    <!-- Navbar sử dụng Bootstrap -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm fixed-top">
        <div class="container-fluid px-4">
            <a class="navbar-brand" href="/">TFC FastOrder</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link fw-medium" href="../">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-medium" href="/Menu">Menu</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-medium" href="#" id="cusOrder">Your Order</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-medium" href="/Home/Contact">Contact</a>
                    </li>

                    @* Menu dành cho Admin *@
                    @if (User.IsInRole("admin"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle fw-medium text-danger" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-cog"></i> Admin
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/Admin/Users"><i class="fas fa-users"></i> Quản lý Users</a></li>
                                <li><a class="dropdown-item" href="/Admin/Products"><i class="fas fa-shopping-bag"></i> Quản lý Products</a></li>
                                <li><a class="dropdown-item" href="/Admin/Combos"><i class="fas fa-burger"></i>Quản lý Combos</a></li>

                            </ul>
                        </li>
                    }

                    @* Menu dành cho Staff *@
                    @if (User.IsInRole("staff") || User.IsInRole("admin"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle fw-medium text-primary" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-utensils"></i> Staff
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/Staff/Orders"><i class="fas fa-list"></i> Đơn hàng mới</a></li>
                            </ul>
                        </li>
                    }
                </ul>

                <div class="d-flex align-items-center">
                    @* Hiển thị thông tin user nếu đã đăng nhập *@
                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="dropdown me-2">
                            <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user"></i> @User.Identity.Name
                                @if (User.IsInRole("admin"))
                                {
                                    <span class="badge bg-danger ms-1">Admin</span>
                                }
                                else if (User.IsInRole("staff"))
                                {
                                    <span class="badge bg-primary ms-1">Staff</span>
                                }
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><h6 class="dropdown-header">@User.FindFirst("Username")?.Value</h6></li>
                                <li>
                                    <span class="dropdown-item-text small text-muted">
                                        Role: @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                                    </span>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" href="/Account/Profile">
                                        <i class="fas fa-user-edit"></i> Thông tin cá nhân
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/Account/ChangePassword">
                                        <i class="fas fa-key"></i> Đổi mật khẩu
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form method="post" action="/Account/Logout" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="fas fa-sign-out-alt"></i> Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn btn-custom text-white fw-medium px-4">
                            <i class="fas fa-sign-in-alt"></i> Login
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- Modal tìm kiếm đơn hàng sử dụng Bootstrap Modal -->
    <div class="modal fade" id="orderModal" tabindex="-1" aria-labelledby="orderModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="orderModalLabel">Tra cứu đơn hàng</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="orderForm">
                        <div class="mb-3">
                            <label for="orderCode" class="form-label">Nhập mã đơn hàng:</label>
                            <input type="tel" class="form-control" id="orderCode" name="orderCode" placeholder="ORD-12345" required>
                        </div>
                        <button type="submit" class="btn btn-primary">Tìm đơn hàng</button>

                        <!-- Loading spinner -->
                        <div class="d-none" id="loadingSpinner">
                            <div class="spinner-border spinner-border-sm me-2" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            Đang tìm kiếm...
                        </div>

                        <!-- Error message -->
                        <div class="alert alert-danger mt-3 d-none" id="errorMessage" role="alert"></div>
                    </form>

                    <!-- Khu vực hiển thị danh sách đơn hàng -->
                    <div id="ordersContainer" class="mt-4 d-none">
                        <h5 id="customerName" class="text-primary"></h5>
                        <div id="ordersList"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <main>
        @RenderBody()
    </main>

    <!-- Footer sử dụng Bootstrap -->
    <footer class="bg-light text-muted text-center py-4">
        <div class="container">
            <div class="row">
                <div class="col-md-6 text-md-start">
                    <p class="mb-0">&copy; @DateTime.Now.Year - TFC FastOrder</p>
                </div>
                <div class="col-md-6 text-md-end">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <small class="text-muted">
                            Đăng nhập bởi: <strong>@User.Identity.Name</strong>
                        </small>
                    }
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

     @if (ViewContext.RouteData.Values["controller"].ToString() == "Staff") 
     { 
         <script src="~/js/Staff.js"></script> 
     } 
     else 
     { 
         <script src="~/js/CustomerOrder.js"></script> 
     } 
   
    
    @RenderSection("Scripts", required: false)
</body>
</html>