<div class="container-fluid" style="margin-top: 80px;">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">
                    <i class="fas fa-layer-group text-primary"></i> Quản Lý Combo
                </h2>
                <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addComboModal">
                    <i class="fas fa-plus"></i> Thêm Combo
                </button>
            </div>
        </div>
    </div>

    <!-- Filter và Search -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-search"></i></span>
                <input type="text" class="form-control" id="searchInput" placeholder="Tìm kiếm combo...">
            </div>
        </div>
        <div class="col-md-3">
            <select class="form-select" id="statusFilter">
                <option value="">Tất cả trạng thái</option>
                <option value="1">Còn hàng</option>
                <option value="0">Hết hàng</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="button" class="btn btn-outline-secondary w-100" id="clearFilters">
                <i class="fas fa-times"></i> Xóa lọc
            </button>
        </div>
    </div>

    <!-- Combos Table -->
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-list"></i> Danh Sách Combo</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="combosTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 60px;">ID</th>
                            <th style="width: 80px;">Hình ảnh</th>
                            <th>Tên combo</th>
                            <th style="width: 150px;">Sản phẩm</th>
                            <th style="width: 120px;">Giá</th>
                            <th style="width: 100px;">Trạng thái</th>
                            <th style="width: 200px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="combosTableBody">
                        <!-- Data will be loaded here -->
                    </tbody>
                </table>
            </div>
            <div id="loadingSpinnerC" class="text-center my-3">
                <div class="spinner-border text-primary" role="status"></div>
                <div class="mt-2">Đang tải dữ liệu...</div>
            </div>
            <div class="text-center p-5 d-none" id="emptyState">
                <i class="fas fa-layer-group fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">Không có combo nào</h5>
                <p class="text-muted">Nhấn "Thêm Combo" để tạo combo đầu tiên</p>
            </div>
        </div>
    </div>
</div>

<!-- Add Combo Modal -->
<div class="modal fade" id="addComboModal" tabindex="-1" aria-labelledby="addComboModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addComboModalLabel">
                    <i class="fas fa-plus text-success"></i> Thêm Combo Mới
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="addComboForm">
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="addComboName" class="form-label">Tên combo *</label>
                                <input type="text" class="form-control" id="addComboName" name="name" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="addComboPrice" class="form-label">Giá *</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" id="addComboPrice" name="price" min="0" step="0.01" required>
                                    <span class="input-group-text">VND</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="addComboDescription" class="form-label">Mô tả</label>
                        <textarea class="form-control" id="addComboDescription" name="description" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="addComboImage" class="form-label">URL Hình ảnh</label>
                        <input type="url" class="form-control" id="addComboImage" name="imageUrl">
                    </div>
                    <div class="mb-3" id="imagePreview" style="display: none;">
                        <label class="form-label">Xem trước:</label>
                        <div class="text-center">
                            <img id="previewImg" src="" alt="Preview" class="img-thumbnail" style="max-width: 200px; max-height: 200px;">
                        </div>
                    </div>

                    <!-- Products Selection -->
                    <div class="mb-3">
                        <label class="form-label">Sản phẩm trong combo *</label>
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <span>Chọn sản phẩm</span>
                                <button type="button" class="btn btn-sm btn-outline-primary" onclick="addProductToCombo()">
                                    <i class="fas fa-plus"></i> Thêm sản phẩm
                                </button>
                            </div>
                            <div class="card-body" id="comboProductsList">
                                <!-- Product items will be added here -->
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success" id="saveAddComboBtn">
                        <i class="fas fa-save"></i> Lưu Combo
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Combo Modal -->
<div class="modal fade" id="editComboModal" tabindex="-1" aria-labelledby="editComboModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editComboModalLabel">
                    <i class="fas fa-edit text-warning"></i> Chỉnh Sửa Combo
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editComboForm">
                <input type="hidden" id="editComboId" name="id">
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="editComboName" class="form-label">Tên combo *</label>
                                <input type="text" class="form-control" id="editComboName" name="name" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="editComboPrice" class="form-label">Giá *</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" id="editComboPrice" name="price" min="0" step="0.01" required>
                                    <span class="input-group-text">VND</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="editComboDescription" class="form-label">Mô tả</label>
                        <textarea class="form-control" id="editComboDescription" name="description" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="editComboImage" class="form-label">URL Hình ảnh</label>
                        <input type="url" class="form-control" id="editComboImage" name="imageUrl">
                    </div>
                    <div class="mb-3" id="editImagePreview" style="display: none;">
                        <label class="form-label">Xem trước:</label>
                        <div class="text-center">
                            <img id="editPreviewImg" src="" alt="Preview" class="img-thumbnail" style="max-width: 200px; max-height: 200px;">
                        </div>
                    </div>

                    <!-- Products Selection -->
                    <div class="mb-3">
                        <label class="form-label">Sản phẩm trong combo *</label>
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <span>Chọn sản phẩm</span>
                                <button type="button" class="btn btn-sm btn-outline-primary" onclick="addProductToEditCombo()">
                                    <i class="fas fa-plus"></i> Thêm sản phẩm
                                </button>
                            </div>
                            <div class="card-body" id="editComboProductsList">
                                <!-- Product items will be added here -->
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-warning" id="saveEditComboBtn">
                        <i class="fas fa-save"></i> Cập Nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteComboModal" tabindex="-1" aria-labelledby="deleteComboModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteComboModalLabel">
                    <i class="fas fa-trash text-danger"></i> Xác Nhận Xóa
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="text-center">
                    <i class="fas fa-exclamation-triangle fa-3x text-warning mb-3"></i>
                    <h5>Bạn có chắc chắn muốn xóa combo này?</h5>
                    <p class="text-muted" id="deleteComboName">Tên combo sẽ hiển thị ở đây</p>
                    <p class="text-danger"><strong>Hành động này không thể hoàn tác!</strong></p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteCombo">
                    <i class="fas fa-trash"></i> Xóa Combo
                </button>
            </div>
        </div>
    </div>
</div>

<!-- View Combo Details Modal -->
<div class="modal fade" id="viewComboModal" tabindex="-1" aria-labelledby="viewComboModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewComboModalLabel">
                    <i class="fas fa-eye text-info"></i> Chi Tiết Combo
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="comboDetailsContent">
                <!-- Combo details will be loaded here -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>
<script src="~/js/Admin_Combo.js"></script>