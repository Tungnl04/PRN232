@model FoodStoreWeb.Controllers.AccountController.ProfileViewModel
@{
    ViewBag.Title = "Thông tin cá nhân";
}

<div class="container" style="margin-top: 100px; margin-bottom: 150px;">
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h4><i class="fas fa-user-circle"></i> Thông tin cá nhân</h4>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Profile" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Name" class="form-label">
                                        <i class="fas fa-user"></i> @Html.DisplayNameFor(m => m.Name)
                                    </label>
                                    <input asp-for="Name" class="form-control" />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Username" class="form-label">
                                        <i class="fas fa-at"></i> @Html.DisplayNameFor(m => m.Username)
                                    </label>
                                    <input asp-for="Username" class="form-control" readonly />
                                    <small class="form-text text-muted">Tên đăng nhập không thể thay đổi</small>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Role" class="form-label">
                                        <i class="fas fa-user-tag"></i> @Html.DisplayNameFor(m => m.Role)
                                    </label>
                                    <input asp-for="Role" class="form-control" readonly />
                                    <small class="form-text text-muted">Role không thể thay đổi</small>

                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">
                                        <i class="fas fa-id-card"></i> ID
                                    </label>
                                    <input value="@Model.Id" class="form-control" readonly />
                                    <small class="form-text text-muted">Id không thể thay đổi</small>
                                </div>
                            </div>
                        </div>

                        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""]?.Errors.Count > 0)
                        {
                            <div class="alert alert-danger">
                                @foreach (var error in ViewData.ModelState[""].Errors)
                                {
                                    <div><i class="fas fa-exclamation-circle"></i> @error.ErrorMessage</div>
                                }
                            </div>
                        }

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Cập nhật thông tin
                            </button>
                            <a asp-action="ChangePassword" class="btn btn-warning">
                                <i class="fas fa-key"></i> Đổi mật khẩu
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <h5><i class="fas fa-info-circle"></i> Thông tin hệ thống</h5>
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        <strong>Trạng thái:</strong>
                        <span class="badge bg-success">
                            <i class="fas fa-check-circle"></i> Đã đăng nhập
                        </span>
                    </div>
                    <div class="mb-2">
                        <strong>Phiên làm việc:</strong>
                        <small class="text-muted">Hoạt động</small>
                    </div>
                    <hr>
                    <form asp-action="Logout" asp-controller="Account" method="post"
                          onsubmit="return confirm('Bạn có chắc muốn đăng xuất?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                            <i class="fas fa-sign-out-alt"></i> Đăng xuất
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

