@page
@model FoodQR.Client.Pages.ChangePasswordModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = null; // Independent page
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đổi mật khẩu - FoodStore QR</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        .pw-hint { font-size: 0.8rem; color: #718096; margin-top: 10px; text-align: left; background: #f7fafc; padding: 10px; border-radius: 8px; border-left: 4px solid #ff4d4d; }
    </style>
</head>
<body class="auth-body">
    <div class="bg-blob" style="top: -100px; right: -100px;"></div>
    <div class="bg-blob" style="bottom: -100px; left: -100px;"></div>

    <div class="login-card">
        <div class="logo-icon"><i class="fa-solid fa-shield-halved"></i></div>
        <h2>Đổi mật khẩu</h2>
        <p class="auth-subtitle">Vì lý do bảo mật, bạn cần đổi mật khẩu mặc định trước khi tiếp tục.</p>

        <form id="change-pw-form">
            <div class="input-group">
                <i class="fa-solid fa-key"></i>
                <input type="password" id="old-password" class="auth-input" placeholder="Mật khẩu hiện tại" required>
            </div>
            <div class="input-group">
                <i class="fa-solid fa-lock"></i>
                <input type="password" id="new-password" class="auth-input" placeholder="Mật khẩu mới" required>
            </div>
            <div class="input-group">
                <i class="fa-solid fa-lock-open"></i>
                <input type="password" id="confirm-password" class="auth-input" placeholder="Xác nhận mật khẩu mới" required>
            </div>

            <div class="pw-hint">
                <i class="fa-solid fa-circle-info"></i> Hãy chọn mật khẩu mạnh để bảo vệ tài khoản của bạn.
            </div>

            <button type="submit" id="btn-submit" class="auth-btn" style="margin-top: 20px;">
                <span id="btn-text">Cập nhật mật khẩu</span>
            </button>
        </form>
    </div>

    <script src="~/js/apiClient.js" asp-append-version="true"></script>
    <script>
        // Check if logged in, if not redirect to login
        if (!apiClient.isAuthenticated()) {
            window.location.href = '/Login';
        }

        document.getElementById('change-pw-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const oldPw = document.getElementById('old-password').value;
            const newPw = document.getElementById('new-password').value;
            const confirmPw = document.getElementById('confirm-password').value;

            if (newPw !== confirmPw) {
                Swal.fire({ icon: 'warning', title: 'Lỗi xác nhận', text: 'Mật khẩu mới và xác nhận mật khẩu không khớp.' });
                return;
            }

            if (newPw === oldPw) {
                Swal.fire({ icon: 'warning', title: 'Lỗi', text: 'Mật khẩu mới không được trùng với mật khẩu cũ.' });
                return;
            }

            const btn = document.getElementById('btn-submit');
            const btnText = document.getElementById('btn-text');
            btn.disabled = true;
            btnText.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang xử lý...';

            try {
                const response = await apiClient.changePassword(oldPw, newPw);
                if (response && response.ok) {
                    localStorage.setItem('must_change_password', 'false');
                    const user = apiClient.getUser();
                    
                    Swal.fire({
                        icon: 'success',
                        title: 'Thành công!',
                        text: 'Mật khẩu đã được cập nhật. Bạn sẽ được chuyển đến trang chủ.',
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => {
                        const role = user.role;
                        if (role === 'admin') window.location.href = '/Admin/Index';
                        else if (role === 'staff') window.location.href = '/Staff/Dashboard';
                        else if (role === 'kitchen') window.location.href = '/Kitchen/Board';
                        else window.location.href = '/';
                    });
                } else {
                    const error = await response.text();
                    Swal.fire({ icon: 'error', title: 'Thất bại', text: error || 'Mật khẩu cũ không đúng hoặc có lỗi xảy ra.' });
                    btn.disabled = false;
                    btnText.innerText = 'Cập nhật mật khẩu';
                }
            } catch (err) {
                Swal.fire({ icon: 'error', title: 'Lỗi hệ thống', text: 'Không thể kết nối với máy chủ.' });
                btn.disabled = false;
                btnText.innerText = 'Cập nhật mật khẩu';
            }
        });
    </script>
</body>
</html>
