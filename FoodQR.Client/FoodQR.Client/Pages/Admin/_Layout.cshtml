<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Portal</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/management.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body class="mgmt-body">
    <div class="sidebar">
        <div class="logo">
            <i class="fa-solid fa-shield-halved"></i>
            <span>Admin</span>
        </div>

        <nav>
            <a href="/Admin/Index" class="nav-item @(ViewContext.RouteData.Values["page"].ToString().Contains("Index") ? "active" : "")">
                <i class="fa-solid fa-chart-line"></i>
                <span>Dashboard</span>
            </a>
            <a href="/Admin/Products" class="nav-item @(ViewContext.RouteData.Values["page"].ToString().Contains("Products") ? "active" : "")">
                <i class="fa-solid fa-burger"></i>
                <span>Products</span>
            </a>
            <a href="/Admin/Categories" class="nav-item @(ViewContext.RouteData.Values["page"].ToString().Contains("Categories") ? "active" : "")">
                <i class="fa-solid fa-list-ul"></i>
                <span>Categories</span>
            </a>
            <a href="/Admin/Tables" class="nav-item @(ViewContext.RouteData.Values["page"].ToString().Contains("Tables") ? "active" : "")">
                <i class="fa-solid fa-table-cells"></i>
                <span>Tables</span>
            </a>
            <a href="/Admin/Users" class="nav-item @(ViewContext.RouteData.Values["page"].ToString().Contains("Users") ? "active" : "")">
                <i class="fa-solid fa-users-gear"></i>
                <span>Users</span>
            </a>
        </nav>

        <div style="margin-top: auto;">
            <a href="#" onclick="apiClient.logout()" class="nav-item" style="color: #ff4d4d;">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Logout</span>
            </a>
        </div>
    </div>

    <div class="main-content">
        <div class="top-bar">
            <h2 id="page-title" style="font-weight: 800; margin: 0;">@ViewData["Title"]</h2>
            <div class="user-profile">
                <div style="text-align: right;">
                    <div class="user-name" id="user-display-name">Admin User</div>
                    <div class="user-role">Administrator</div>
                </div>
                <div style="width: 40px; height: 40px; border-radius: 50%; background: #ff4d4d; color: white; display: flex; align-items: center; justify-content: center;">
                    <i class="fa-solid fa-user-shield"></i>
                </div>
            </div>
        </div>
        @RenderBody()
    </div>

    <script src="~/js/apiClient.js" asp-append-version="true"></script>
    <script>
        if (!apiClient.isAuthenticated() || apiClient.getUser().role !== 'admin') {
            apiClient.logout();
        }
        document.getElementById('user-display-name').innerText = apiClient.getUser().name || 'Admin';
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
