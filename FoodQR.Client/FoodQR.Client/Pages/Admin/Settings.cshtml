@page
@model FoodQR.Client.Pages.Admin.SettingsModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Cài đặt cửa hàng";
}

<div style="max-width: 700px; margin: 0 auto;">
    <div class="card-mgmt" style="padding: 35px;">
        <h3 style="margin: 0 0 8px; font-weight: 900; font-size: 1.3rem; display: flex; align-items: center; gap: 10px;">
            <i class="fa-solid fa-store" style="color: var(--primary);"></i> Thông tin cửa hàng
        </h3>
        <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 30px;">Cấu hình tên cửa hàng và thông số hiển thị trên hóa đơn.</p>

        <div style="display: flex; flex-direction: column; gap: 24px;">
            <div>
                <label style="font-size: 0.85rem; font-weight: 700; color: var(--text-muted); display: block; margin-bottom: 8px;">Tên cửa hàng</label>
                <input type="text" id="store-name" placeholder="VD: FoodQR Restaurant"
                       style="width: 100%; box-sizing: border-box; padding: 14px 16px; border-radius: 12px; border: 1.5px solid #e2e8f0; font-family: inherit; font-weight: 600; font-size: 0.95rem; outline: none; transition: border-color 0.2s;" />
            </div>

            <div>
                <label style="font-size: 0.85rem; font-weight: 700; color: var(--text-muted); display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                    Thuế VAT (%)
                    <span class="tooltip-icon" title="Theo Nghị định 15/2022/NĐ-CP, mức thuế VAT cho dịch vụ ăn uống hiện tại là 8%">
                        <i class="fa-solid fa-circle-info" style="color: #3b82f6; cursor: help;"></i>
                    </span>
                </label>
                <div style="position: relative;">
                    <input type="number" id="tax-rate" min="0" max="100" step="0.1" placeholder="8"
                           style="width: 100%; box-sizing: border-box; padding: 14px 50px 14px 16px; border-radius: 12px; border: 1.5px solid #e2e8f0; font-family: inherit; font-weight: 700; font-size: 1.1rem; outline: none; transition: border-color 0.2s;" />
                    <span style="position: absolute; right: 18px; top: 50%; transform: translateY(-50%); font-weight: 800; color: var(--text-muted); font-size: 1rem;">%</span>
                </div>
                <div style="margin-top: 10px; padding: 10px 14px; background: #eff6ff; border-radius: 10px; border-left: 3px solid #3b82f6;">
                    <p style="font-size: 0.75rem; color: #1e40af; font-weight: 600; margin: 0; line-height: 1.5;">
                        <i class="fa-solid fa-lightbulb" style="margin-right: 4px;"></i>
                        Theo Nghị định 15/2022/NĐ-CP, mức thuế VAT cho dịch vụ ăn uống hiện tại là <strong>8%</strong>.
                    </p>
                </div>
            </div>

            <div>
                <label style="display: flex; align-items: center; gap: 12px; cursor: pointer; padding: 14px 16px; background: #f8fafc; border-radius: 12px; border: 1.5px solid #e2e8f0; transition: all 0.2s;">
                    <input type="checkbox" id="tax-included" style="width: 20px; height: 20px; accent-color: var(--primary); cursor: pointer;" />
                    <div>
                        <span style="font-weight: 700; font-size: 0.9rem; color: var(--text-main);">Giá trên menu đã bao gồm thuế</span>
                        <p style="font-size: 0.75rem; color: var(--text-muted); margin: 4px 0 0; font-weight: 600;">
                            Nếu bật, thuế sẽ không cộng thêm vào tổng hóa đơn mà được tách ra hiển thị.
                        </p>
                    </div>
                </label>
            </div>

            <div>
                <label style="font-size: 0.85rem; font-weight: 700; color: var(--text-muted); display: block; margin-bottom: 8px;">Đơn vị tiền tệ</label>
                <select id="currency"
                        style="width: 100%; box-sizing: border-box; padding: 14px 16px; border-radius: 12px; border: 1.5px solid #e2e8f0; font-family: inherit; font-weight: 600; font-size: 0.95rem; outline: none; background: white; cursor: pointer;">
                    <option value="VND">VND - Việt Nam Đồng</option>
                </select>
            </div>
        </div>

        <div style="margin-top: 35px; display: flex; align-items: center; justify-content: space-between;">
            <span id="save-status" style="font-size: 0.8rem; color: #22c55e; font-weight: 700; opacity: 0; transition: opacity 0.3s;">
                <i class="fa-solid fa-check-circle"></i> Đã lưu thay đổi
            </span>
            <button onclick="saveConfig()" id="btn-save"
                    style="padding: 14px 40px; background: var(--primary); color: white; border: none; border-radius: 12px; font-weight: 800; font-size: 0.95rem; cursor: pointer; box-shadow: 0 4px 0 #cc0000; transition: all 0.1s;">
                <i class="fa-solid fa-floppy-disk"></i> Lưu cài đặt
            </button>
        </div>
    </div>

    <div class="card-mgmt" style="padding: 25px; margin-top: 24px; border-left: 3px solid #fbbf24;">
        <div style="display: flex; align-items: flex-start; gap: 12px;">
            <i class="fa-solid fa-triangle-exclamation" style="color: #fbbf24; font-size: 1.2rem; margin-top: 2px;"></i>
            <div>
                <h4 style="margin: 0 0 6px; font-weight: 800; color: var(--text-main); font-size: 0.95rem;">Lưu ý quan trọng</h4>
                <p style="font-size: 0.8rem; color: var(--text-muted); line-height: 1.6; margin: 0;">
                    Thay đổi thuế VAT sẽ ảnh hưởng đến <strong>tất cả hóa đơn mới</strong> từ thời điểm lưu. 
                    Các đơn hàng đã thanh toán trước đó không bị thay đổi.
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    input:focus, select:focus { border-color: var(--primary) !important; box-shadow: 0 0 0 3px rgba(255, 77, 77, 0.08); }
    #btn-save:active { transform: translateY(2px); box-shadow: 0 2px 0 #cc0000; }
</style>

@section Scripts {
    <script>
        async function loadConfig() {
            try {
                const res = await fetch(`${apiBase}/StoreConfig`);
                if (!res.ok) return;
                const config = await res.json();
                document.getElementById('store-name').value = config.storeName || '';
                document.getElementById('tax-rate').value = (config.taxRate * 100).toFixed(1);
                document.getElementById('tax-included').checked = config.isTaxIncludedInPrice;
                document.getElementById('currency').value = config.currency || 'VND';
            } catch (e) { console.error('Lỗi tải cấu hình', e); }
        }

        async function saveConfig() {
            const btn = document.getElementById('btn-save');
            const statusEl = document.getElementById('save-status');
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang lưu...';

            const taxPercent = parseFloat(document.getElementById('tax-rate').value);
            if (isNaN(taxPercent) || taxPercent < 0 || taxPercent > 100) {
                Swal.fire({ icon: 'error', title: 'Lỗi', text: 'Thuế VAT phải từ 0% đến 100%' });
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Lưu cài đặt';
                return;
            }

            try {
                const token = localStorage.getItem('auth_token');
                const res = await fetch(`${apiBase}/StoreConfig`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                    body: JSON.stringify({
                        storeName: document.getElementById('store-name').value,
                        taxRate: taxPercent / 100,
                        isTaxIncludedInPrice: document.getElementById('tax-included').checked,
                        currency: document.getElementById('currency').value
                    })
                });

                if (res.ok) {
                    statusEl.style.opacity = '1';
                    setTimeout(() => statusEl.style.opacity = '0', 3000);
                    Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Đã lưu cài đặt!', timer: 2000, showConfirmButton: false });
                } else {
                    const err = await res.json();
                    Swal.fire({ icon: 'error', title: 'Lỗi', text: err.error || 'Không thể lưu.' });
                }
            } catch (e) {
                Swal.fire({ icon: 'error', title: 'Lỗi kết nối', text: 'Không thể kết nối đến server.' });
            }

            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Lưu cài đặt';
        }

        loadConfig();
    </script>
}
