@page
@model FoodQR.Client.Pages.Admin.ProductsModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Manage Products";
}

<div class="card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h3 style="font-weight: 800; margin: 0;">Product List</h3>
        <button onclick="openCreateModal()" class="btn btn-primary" style="background: var(--primary); color: white; border: none; padding: 10px 20px; border-radius: 12px; font-weight: 600; cursor: pointer;">
            <i class="fa-solid fa-plus"></i> Add Product
        </button>
    </div>

    <table class="mgmt-table">
        <thead>
            <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="product-table-body">
            <!-- Rendered via JS -->
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        const apiBaseUrl = "@(ViewData["ApiBaseUrl"])" || (window.location.hostname.includes('localhost') ? "https://localhost:7197/api" : "https://foodqrrestaurant-cbdwbzfcfxecdfay.southeastasia-01.azurewebsites.net/api");
        const baseUrl = apiBaseUrl.replace('/api', '');
        
        function getImageUrl(url) {
            if (!url) return '/images/placeholder.png';
            if (url.startsWith('http')) return url;
            return baseUrl + url;
        }

        let products = [];
        let categories = [];

        async function init() {
            categories = await apiClient.getCategories();
            await loadProducts();
        }

        async function loadProducts() {
            products = await apiClient.getProducts();
            const body = document.getElementById('product-table-body');
            body.innerHTML = products.map(p => {
                const cat = categories.find(c => c.id === p.categoryId);
                return `
                <tr>
                    <td><img src="${getImageUrl(p.imageUrl)}" style="width: 40px; height: 40px; border-radius: 8px; object-fit: cover;"></td>
                    <td class="font-bold">${p.name}</td>
                    <td>${cat ? cat.name : '<span class="text-muted">None</span>'}</td>
                    <td class="currency-amount">${apiClient.formatVnd(p.price || 0)}</td>
                    <td>
                        <span style="font-weight: 600; color: ${(p.inventory ?? 0) <= 5 ? '#f44336' : '#4caf50'}">
                            ${p.inventory != null ? p.inventory : '∞'}
                        </span>
                    </td>
                    <td>
                        <span class="status-badge ${p.isAvailable ? 'active' : 'inactive'}" style="padding: 4px 10px; border-radius: 12px; font-size: 0.7rem;">
                            ${p.isAvailable ? 'Available' : 'Out of Stock'}
                        </span>
                    </td>
                    <td>
                        <div style="display: flex; gap: 8px;">
                            <button class="btn-icon" onclick="openEditModal(${p.id})" title="Edit"><i class="fa-solid fa-pen-to-square"></i></button>
                            <button class="btn-icon danger" onclick="deleteProduct(${p.id})" title="Delete"><i class="fa-solid fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            `}).join('');
        }

        async function openCreateModal() {
            const catOptions = categories.map(c => `<option value="${c.id}">${c.name}</option>`).join('');
            
            const { value: formValues } = await Swal.fire({
                title: 'Add New Product',
                html: `
                    <div style="text-align: left;">
                        <label class="swal-label">Name</label>
                        <input id="swal-name" class="swal2-input" placeholder="Product Name">
                        
                        <label class="swal-label">Category</label>
                        <select id="swal-category" class="swal2-select">${catOptions}</select>
                        
                        <div style="display: flex; gap: 15px;">
                            <div style="flex: 1;">
                                <label class="swal-label">Price</label>
                                <input id="swal-price" type="number" class="swal2-input" placeholder="Price">
                            </div>
                            <div style="flex: 1;">
                                <label class="swal-label">Stock (Tồn kho)</label>
                                <input id="swal-inventory" type="number" class="swal2-input" placeholder="100">
                            </div>
                        </div>

                        <label class="swal-label">Description</label>
                        <textarea id="swal-desc" class="swal2-textarea" placeholder="Description..." rows="3"></textarea>
                        
                        <label class="swal-label">Upload Image</label>
                        <input type="file" id="swal-image-file" class="swal2-file" accept="image/*">
                        
                        <label class="swal-label">Or Existing Image URL</label>
                        <input id="swal-image" class="swal2-input" placeholder="https://...">
                    </div>
                `,
                focusConfirm: false,
                preConfirm: async () => {
                    let finalImageUrl = document.getElementById('swal-image').value;
                    const fileInput = document.getElementById('swal-image-file');
                    if (fileInput.files.length > 0) {
                        const uploadedUrl = await apiClient.uploadImage(fileInput.files[0]);
                        if (uploadedUrl) {
                            finalImageUrl = uploadedUrl;
                        } else {
                            Swal.showValidationMessage('Failed to upload image. Please try again.');
                            return false;
                        }
                    }

                    return {
                        name: document.getElementById('swal-name').value,
                        categoryId: parseInt(document.getElementById('swal-category').value),
                        price: parseFloat(document.getElementById('swal-price').value),
                        description: document.getElementById('swal-desc').value,
                        imageUrl: finalImageUrl,
                        inventory: parseInt(document.getElementById('swal-inventory').value) || 0,
                        isAvailable: true
                    }
                }
            });

            if (formValues && formValues.name) {
                const res = await apiClient.createProduct(formValues);
                if (res && res.ok) {
                    Swal.fire('Success!', 'Product created.', 'success');
                    loadProducts();
                }
            }
        }

        async function openEditModal(id) {
            const p = products.find(x => x.id === id);
            const catOptions = categories.map(c => `<option value="${c.id}" ${c.id === p.categoryId ? 'selected' : ''}>${c.name}</option>`).join('');
            
            const { value: formValues } = await Swal.fire({
                title: 'Edit Product',
                html: `
                    <div style="text-align: left;">
                        <label class="swal-label">Name</label>
                        <input id="swal-name" class="swal2-input" value="${p.name}">
                        
                        <label class="swal-label">Category</label>
                        <select id="swal-category" class="swal2-select">${catOptions}</select>
                        
                        <div style="display: flex; gap: 15px;">
                            <div style="flex: 1;">
                                <label class="swal-label">Price</label>
                                <input id="swal-price" type="number" class="swal2-input" value="${p.price}">
                            </div>
                            <div style="flex: 1;">
                                <label class="swal-label">Stock (Tồn kho)</label>
                                <input id="swal-inventory" type="number" class="swal2-input" value="${p.inventory != null ? p.inventory : ''}" placeholder="Trống = ∞">
                            </div>
                        </div>

                        <label class="swal-label">Description</label>
                        <textarea id="swal-desc" class="swal2-textarea" rows="3">${p.description || ''}</textarea>
                        
                        <label class="swal-label">Upload New Image</label>
                        <input type="file" id="swal-image-file" class="swal2-file" accept="image/*">
                        
                        <label class="swal-label">Or Existing Image URL</label>
                        <input id="swal-image" class="swal2-input" value="${p.imageUrl || ''}">
                        
                        <div class="swal2-checkbox-container">
                            <input type="checkbox" id="swal-available" ${p.isAvailable ? 'checked' : ''}>
                            <label for="swal-available">Is Available (Mở bán)</label>
                        </div>
                    </div>
                `,
                focusConfirm: false,
                preConfirm: async () => {
                    let finalImageUrl = document.getElementById('swal-image').value;
                    const fileInput = document.getElementById('swal-image-file');
                    if (fileInput.files.length > 0) {
                        const uploadedUrl = await apiClient.uploadImage(fileInput.files[0]);
                        if (uploadedUrl) {
                            finalImageUrl = uploadedUrl;
                        } else {
                            Swal.showValidationMessage('Failed to upload image. Please try again.');
                            return false;
                        }
                    }

                    return {
                        id: p.id,
                        name: document.getElementById('swal-name').value,
                        categoryId: parseInt(document.getElementById('swal-category').value),
                        price: parseFloat(document.getElementById('swal-price').value),
                        description: document.getElementById('swal-desc').value,
                        imageUrl: finalImageUrl,
                        inventory: document.getElementById('swal-inventory').value ? parseInt(document.getElementById('swal-inventory').value) : null,
                        isAvailable: document.getElementById('swal-available').checked
                    }
                }
            });

            if (formValues) {
                const res = await apiClient.updateProduct(id, formValues);
                if (res && res.ok) {
                    Swal.fire('Updated!', 'Product saved.', 'success');
                    loadProducts();
                }
            }
        }

        async function deleteProduct(id) {
            const result = await Swal.fire({
                title: 'Ngừng bán món ăn này?',
                text: "Món ăn sẽ bị đưa vào kho lưu trữ (Xóa mềm) để bảo toàn dữ liệu kế toán.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ff4d4d',
                confirmButtonText: 'Yes, delete it!'
            });

            if (result.isConfirmed) {
                const res = await apiClient.deleteProduct(id);
                if (res && res.ok) {
                    Swal.fire('Deleted!', 'Product removed.', 'success');
                    loadProducts();
                }
            }
        }

        window.addEventListener('DOMContentLoaded', init);
    </script>
}

<style>
    .status-badge.active { background: #e8f5e9; color: #4caf50; }
    .status-badge.inactive { background: #ffebee; color: #f44336; }
    
    /* Modern SweetAlert Customization */
    .swal2-popup { width: 550px !important; border-radius: 20px !important; padding: 24px 30px !important; box-shadow: 0 10px 40px rgba(0,0,0,0.1) !important; }
    .swal2-title { font-weight: 800 !important; color: #1e293b !important; font-size: 1.5rem !important; margin-bottom: 5px !important; }
    .swal2-html-container { text-align: left; margin: 15px 0 0 0 !important; }
    
    .swal2-input, .swal2-textarea, .swal2-select, .swal2-file {
        width: 100% !important;
        box-sizing: border-box !important;
        margin: 0 0 18px 0 !important;
        font-size: 0.95rem !important;
        padding: 12px 16px !important;
        border: 1.5px solid #cbd5e1 !important;
        border-radius: 12px !important;
        transition: all 0.2s !important;
        box-shadow: none !important;
        font-family: inherit !important;
    }
    .swal2-input:focus, .swal2-textarea:focus, .swal2-select:focus {
        border-color: var(--primary) !important;
        box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.08) !important;
    }
    .swal-label {
        display: block;
        font-size: 0.85rem;
        font-weight: 700;
        color: #64748b;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .swal2-checkbox-container {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 5px;
        padding: 14px 18px;
        background: #f8fafc;
        border-radius: 12px;
        border: 1.5px solid #e2e8f0;
        transition: border-color 0.2s;
    }
    .swal2-checkbox-container:hover { border-color: #cbd5e1; }
    .swal2-checkbox-container input[type="checkbox"] {
        width: 18px; height: 18px; accent-color: var(--primary); cursor: pointer;
    }
    .swal2-checkbox-container label {
        margin: 0; font-weight: 700; color: #1e293b; cursor: pointer; font-size: 0.9rem;
    }
</style>
