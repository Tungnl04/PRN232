@page
@model FoodQR.Client.Pages.Staff.DashboardModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Quản lý Bàn";
}

<div class="table-grid" id="table-list">
    <div style="padding: 40px; text-align: center; width: 100%;">
        <i class="fa-solid fa-spinner fa-spin" style="font-size: 2rem; color: var(--primary);"></i>
        <p>Đang tải danh sách bàn...</p>
    </div>
</div>

<link rel="stylesheet" href="~/css/staff/dashboard.css" asp-append-version="true" />

@section Scripts {
    <script>
        let tables = [];
        async function loadTables() {
            try {
                tables = await apiClient.getTables();
                renderTables(tables);
            } catch (err) { console.error(err); }
        }

        function renderTables(tables) {
            const container = document.getElementById('table-list');
            container.innerHTML = tables.map(t => {
                const status = t.status.toLowerCase();
                let statusVN = "Trống";
                let statusClass = "status-available";
                if (status === 'taken') { statusVN = "Có khách"; statusClass = "status-taken"; }
                if (status === 'cleaning') { statusVN = "Chờ dọn"; statusClass = "status-cleaning"; }

                return `
                    <div class="card-mgmt ${status === 'taken' ? 'status-taken-border' : ''}">
                        <span class="status-badge ${statusClass}">${statusVN}</span>
                        <div class="table-number">Bàn ${t.tableNumber}</div>
                        <div class="table-info"><i class="fa-solid fa-users"></i> Sức chứa: ${t.capacity} người</div>
                        
                        <div class="btn-group">
                            <button class="btn btn-outline" onclick="viewTable(${t.id})">
                                <i class="fa-solid fa-eye"></i> Chi tiết
                            </button>
                            ${status === 'taken' ? `
                                <button class="btn btn-primary" onclick="viewTable(${t.id})">
                                    <i class="fa-solid fa-receipt"></i> Đang gọi...
                                </button>
                            ` : status === 'cleaning' ? `
                                <button class="btn btn-warning" onclick="cleanTable(${t.id})">
                                    <i class="fa-solid fa-broom"></i> Dọn xong
                                </button>
                            ` : `
                                <button class="btn btn-success" onclick="openTable(${t.id})">
                                    <i class="fa-solid fa-play"></i> Mở bàn
                                </button>
                            `}
                        </div>
                    </div>
                `;
            }).join('');
        }

        async function cleanTable(id) {
            const res = await apiClient.updateTableStatus(id, 'available');
            if (res && res.ok) {
                Swal.fire({ toast:true, position:'top-end', icon:'success', title:'Hệ thống: Bàn đã trống!', showConfirmButton:false, timer:1500 });
                loadTables();
            }
        }

        async function openTable(id) {
            const res = await apiClient.updateTableStatus(id, 'taken');
            if (res && res.ok) loadTables();
        }

        function viewTable(id) {
            const t = tables.find(x => x.id === id);
            const token = t?.qrCodeToken || '';
            window.location.href = `/Staff/OrderDetails?tableId=${id}&qrToken=${token}&tableNumber=${t.tableNumber}`;
        }

        loadTables();
        setInterval(loadTables, 10000);
    </script>
}
