<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Staff Portal</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/management.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body class="mgmt-body">
    <div class="sidebar">
        <div class="logo">
            <i class="fa-solid fa-user-tie"></i>
            <span>Staff</span>
        </div>

        <nav>
            <a href="/Staff/Dashboard" class="nav-item @(ViewContext.RouteData.Values["page"].ToString().Contains("Dashboard") ? "active" : "")">
                <i class="fa-solid fa-table-cells"></i>
                <span>Table Map</span>
            </a>
            <a href="/Staff/Notifications" class="nav-item @(ViewContext.RouteData.Values["page"].ToString().Contains("Notifications") ? "active" : "")">
                <i class="fa-solid fa-bell"></i>
                <span>Alerts</span>
            </a>
        </nav>

        <div style="margin-top: auto;">
            <a href="#" onclick="apiClient.logout()" class="nav-item" style="color: #ff4d4d;">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Logout</span>
            </a>
        </div>
    </div>

    <div class="main-content">
        <div class="top-bar">
            <h2 id="page-title" style="font-weight: 800; margin: 0;">@ViewData["Title"]</h2>
            <div class="user-profile">
                <div style="text-align: right;">
                    <div class="user-name" id="user-display-name">Staff User</div>
                    <div class="user-role">Service Team</div>
                </div>
                <div style="width: 40px; height: 40px; border-radius: 50%; background: #eee; display: flex; align-items: center; justify-content: center;">
                    <i class="fa-solid fa-user-service"></i>
                </div>
            </div>
        </div>
        @RenderBody()
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/apiClient.js" asp-append-version="true"></script>
    <script>
        if (!apiClient.isAuthenticated() || (apiClient.getUser().role !== 'staff' && apiClient.getUser().role !== 'admin')) {
            apiClient.logout();
        }
        document.getElementById('user-display-name').innerText = apiClient.getUser().name || 'Staff';

        // === SignalR Connection ===
        const staffConnection = new signalR.HubConnectionBuilder()
            .withUrl('https://localhost:7197/hubs/order')
            .withAutomaticReconnect()
            .build();

        staffConnection.on('NewOrderReceived', (data) => {
            console.log('📦 New order received:', data);
            Swal.fire({
                icon: 'info',
                title: '🔔 Đơn mới!',
                text: `Bàn ${data.tableId} vừa đặt đơn ${data.orderCode}`,
                timer: 4000,
                showConfirmButton: false,
                position: 'top-end',
                toast: true
            });
            // Reload data nếu đang ở trang cụ thể
            if (typeof loadTables === 'function') loadTables();
        });

        staffConnection.on('ItemStatusChanged', (data) => {
            console.log('🔄 Item status changed:', data);
            if (typeof loadOrder === 'function') loadOrder();
            if (typeof loadTables === 'function') loadTables();
        });

        staffConnection.on('OrderReady', (data) => {
            console.log('✅ Order ready:', data);
            Swal.fire({
                icon: 'success',
                title: '✅ Đơn sẵn sàng!',
                text: `Đơn ${data.orderCode} (Bàn ${data.tableId}) đã sẵn sàng phục vụ!`,
                timer: 5000,
                showConfirmButton: false,
                position: 'top-end',
                toast: true
            });
        });

        staffConnection.on('NewNotification', (data) => {
            console.log('🔔 Notification:', data);
            Swal.fire({
                icon: 'warning',
                title: '🔔 Thông báo!',
                text: data.message,
                timer: 5000,
                showConfirmButton: false,
                position: 'top-end',
                toast: true
            });
        });

        staffConnection.start()
            .then(() => {
                console.log('✅ SignalR connected (Staff)');
                staffConnection.invoke('JoinGroup', 'staff');
            })
            .catch(err => console.error('SignalR Error:', err));
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
