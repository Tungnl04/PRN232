@inject IConfiguration Configuration
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nhân viên</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/staff/layout.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body class="mgmt-body">
    <aside class="sidebar" id="sidebar">
        <a href="/" class="logo">
            <i class="fa-solid fa-user-tie"></i>
            <span>FOOD<span style="color:var(--primary)">QR</span></span>
        </a>

        <nav class="nav-group">
            <a href="/Staff/Dashboard" class="nav-item @(ViewContext.RouteData.Values["page"]?.ToString().Contains("Dashboard") == true ? "active" : "")">
                <i class="fa-solid fa-table-cells"></i><span>Sơ đồ bàn</span>
            </a>
            <a href="/Staff/KitchenBoard" class="nav-item @(ViewContext.RouteData.Values["page"]?.ToString().Contains("KitchenBoard") == true ? "active" : "")">
                <i class="fa-solid fa-kitchen-set"></i><span>Xem Bếp</span>
            </a>
        </nav>

        <div class="logout-section">
            <a href="#" onclick="apiClient.logout()" class="nav-item" style="color: #ff4d4d; background: #fff5f5;">
                <i class="fa-solid fa-arrow-right-from-bracket"></i><span>Đăng xuất</span>
            </a>
        </div>
    </aside>

    <main class="main-content">
        <header class="top-bar">
            <div style="display: flex; align-items: center; gap: 15px;">
                <button class="mobile-toggle" style="display:none" id="m-toggle" onclick="document.getElementById('sidebar').classList.toggle('active')">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <div class="page-info"><h2>@ViewData["Title"]</h2></div>
            </div>

            <div class="user-actions">
                <div class="bell-btn">
                    <button class="mobile-toggle" style="box-shadow: none; border: 1px solid #f0f0f0;" onclick="toggleNotifications()">
                        <i class="fa-solid fa-bell"></i>
                    </button>
                    <div class="bell-badge" id="notif-badge">0</div>
                    <div class="notification-dropdown" id="notif-dropdown">
                        <div class="notification-header">
                            <h4>Thông báo</h4>
                            <span style="font-size: 0.7rem; color: var(--primary); font-weight: 700; cursor: pointer;" onclick="clearNotifs()">Xóa hết</span>
                        </div>
                        <div class="notification-list" id="notif-list">
                            <div class="notification-empty">Không có thông báo mới</div>
                        </div>
                    </div>
                </div>

                <div class="profile-badge">
                    <div style="text-align: right; line-height: 1.2;">
                        <div class="name" id="user-display-name">Loading...</div>
                        <div style="font-size: 0.65rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase;">NHÂN VIÊN</div>
                    </div>
                    <div class="profile-img" id="user-initial">?</div>
                </div>
            </div>
        </header>

        @RenderBody()
    </main>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/apiClient.js" asp-append-version="true"></script>
    <script>
        const user = apiClient.getUser();
        if (!user || (user.role !== 'staff' && user.role !== 'admin')) apiClient.logout();
        document.getElementById('user-display-name').innerText = user.name || 'Nhân viên';
        document.getElementById('user-initial').innerText = (user.name || 'N')[0].toUpperCase();

        const configBase = "@(Configuration["ApiSettings:BaseUrl"])";
        const apiBase = (configBase && !configBase.includes("YOUR_API_DOMAIN")) ? configBase : (window.location.hostname.includes('localhost') ? "https://localhost:7197/api" : "https://foodqrrestaurant-cbdwbzfcfxecdfay.southeastasia-01.azurewebsites.net/api");
        const connection = new signalR.HubConnectionBuilder()
            .withUrl(apiBase.replace('/api', '') + '/hubs/order')
            .withAutomaticReconnect().build();

        connection.on('NewOrderReceived', (data) => {
            addNotification(Math.floor(Math.random() * 1000000) * -1, `Đơn mới từ Bàn ${data.tableId}`, `Vừa nhận đơn hàng ${data.orderCode}`);
            if (window.onNewOrder) window.onNewOrder(data);
        });

        connection.on('NewNotification', (data) => {
            addNotification(data.id, 'Yêu cầu hỗ trợ', data.message);
        });

        connection.start().then(() => connection.invoke('JoinGroup', 'staff')).catch(console.error);

        let notifications = [];
        
        async function loadNotificationHistory() {
            try {
                const token = sessionStorage.getItem('auth_token') || localStorage.getItem('auth_token');
                const res = await fetch(`${apiBase}/Notifications?role=staff`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if (res.ok) {
                    const data = await res.json();
                    notifications = data.map(n => ({
                        id: n.id,
                        title: 'Thông báo',
                        message: n.message,
                        time: new Date(n.createdAt).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' }),
                        isRead: n.isRead
                    }));
                    renderNotifications();
                }
            } catch (e) {
                console.error("Load notifications error", e);
            }
        }

        function addNotification(id, title, message) {
            notifications.unshift({ id, title, message, time: new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' }), isRead: false });
            if (notifications.length > 20) notifications.pop();
            renderNotifications();
            Swal.fire({ 
                toast: true, position: 'top-end', icon: 'info', 
                title: `🔔 ${title}`, text: message, 
                timer: 6000,
                showConfirmButton: true,
                confirmButtonText: 'OK',
            }).then((result) => {
                if (result.isConfirmed && id > 0) {
                    markAsRead(id);
                }
            });
        }

        async function markAsRead(id) {
            const n = notifications.find(x => x.id === id);
            if (!n || n.isRead) return;
            
            try {
                const token = sessionStorage.getItem('auth_token') || localStorage.getItem('auth_token');
                
                // If it's a real notification mapped in DB (id > 0)
                if (id > 0) {
                    await fetch(`${apiBase}/Notifications/${id}/read`, {
                        method: 'PATCH',
                        headers: { 'Authorization': `Bearer ${token}` }
                    });
                }
                
                n.isRead = true; 
                renderNotifications();
            } catch(e) { console.error(e); }
        }

        function renderNotifications() {
            const list = document.getElementById('notif-list');
            const badge = document.getElementById('notif-badge');
            
            const unreadCount = notifications.filter(n => !n.isRead).length;
            if (unreadCount === 0) {
                badge.classList.remove('active');
            } else {
                badge.innerText = unreadCount;
                badge.classList.add('active');
            }
            
            if (notifications.length === 0) {
                list.innerHTML = '<div class="notification-empty">Không có thông báo mới</div>';
                return;
            }
            
            list.innerHTML = notifications.map(n => `
                <div class="notification-item ${n.isRead ? 'read' : 'unread'}" style="cursor: pointer; padding: 12px; border-bottom: 1px solid #f0f0f0; display: flex; align-items: flex-start; gap: 10px; transition: all 0.2s; ${!n.isRead ? 'background: rgba(59,130,246,0.05); border-left: 3px solid #3b82f6;' : 'opacity: 0.7;'}" onclick="event.stopPropagation(); markAsRead(${n.id})">
                    <i class="fa-solid ${n.isRead ? 'fa-bell-slash' : 'fa-bell'}" style="color: ${n.isRead ? '#ccc' : 'var(--primary)'}; margin-top: 4px;"></i>
                    <div class="text" style="flex: 1;">
                        <div style="font-weight: 800; font-size: 0.8rem; display: flex; justify-content: space-between; color: var(--text-main);">
                            ${n.title} 
                            ${!n.isRead ? '<span style="color:#3b82f6; font-size: 0.7rem; background: #eff6ff; padding: 2px 6px; border-radius: 4px;">Mới</span>' : ''}
                        </div>
                        <div style="font-size: 0.8rem; color: #555; margin: 4px 0;">${n.message}</div>
                        <div class="time" style="font-size: 0.7rem; color: #aaa;">${n.time}</div>
                    </div>
                </div>
            `).join('');
        }

        function toggleNotifications() { document.getElementById('notif-dropdown').classList.toggle('show'); }
        function clearNotifs() { 
            const oldNotifs = [...notifications];
            notifications = [];
            renderNotifications(); 
            
            oldNotifs.forEach(async n => { 
                if (!n.isRead && n.id > 0) {
                    try {
                        const token = sessionStorage.getItem('auth_token') || localStorage.getItem('auth_token');
                        await fetch(`${apiBase}/Notifications/${n.id}/read`, {
                            method: 'PATCH',
                            headers: { 'Authorization': `Bearer ${token}` }
                        });
                    } catch(e) {}
                }
            });
        }
        
        document.addEventListener('DOMContentLoaded', () => {
            loadNotificationHistory();
        });

        document.addEventListener('click', (e) => { if (!e.target.closest('.bell-btn')) document.getElementById('notif-dropdown').classList.remove('show'); });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
