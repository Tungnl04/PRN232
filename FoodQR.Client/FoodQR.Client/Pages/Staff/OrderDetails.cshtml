@page
@model FoodQR.Client.Pages.Staff.OrderDetailsModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Chi tiết Đơn hàng";
}

<div style="margin-bottom: 24px;">
    <a href="/Staff/Dashboard" style="color: var(--text-main); font-weight: 800; text-decoration: none; display: inline-flex; align-items: center; gap: 8px;">
        <i class="fa-solid fa-arrow-left"></i> Quay lại Sơ đồ bàn
    </a>
</div>

<div style="display: grid; grid-template-columns: 1fr 300px; gap: 24px; align-items: start;">

    <!-- Thông tin đơn hàng -->
    <div class="card-mgmt" style="padding: 30px;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 30px;">
            <div>
                <h3 style="margin: 0; font-weight: 900; font-size: 1.5rem;">Đơn hàng Bàn #<span id="order-id">--</span></h3>
                <div style="color: var(--text-muted); font-size: 0.95rem; margin-top: 5px;">Trạng thái: <span id="order-status" style="font-weight: 800; color: var(--primary);">--</span></div>
            </div>
            <div id="payment-status"></div>
        </div>

        <div id="batch-serve-bar" style="display: none; margin-bottom: 15px;">
            <button id="btn-serve-all" onclick="serveAll()" class="btn-serve" style="width: 100%; padding: 14px; font-size: 0.95rem; border-radius: 14px; display: flex; align-items: center; justify-content: center; gap: 8px;">
                <i class="fa-solid fa-check-double"></i> GIAO TẤT CẢ
            </button>
        </div>

        <div id="items-list" style="display: flex; flex-direction: column; gap: 15px;">
            <div style="text-align:center; padding: 40px; color: #ccc;">
                <i class="fa-solid fa-spinner fa-spin fa-2x"></i>
                <p>Đang tải món ăn...</p>
            </div>
        </div>

        <div id="order-total-container" style="margin-top: 40px; text-align: right; border-top: 2px dashed #eee; padding-top: 25px;">
            <div style="color: var(--text-muted); font-weight: 600; font-size: 0.9rem; margin-bottom: 5px;">Tổng cộng thanh toán</div>
            <div id="order-total" style="font-size: 2rem; font-weight: 900; color: var(--primary);">0 ₫</div>
        </div>
    </div>

    <!-- QR Code bàn -->
    <div class="card-mgmt" style="text-align: center; padding: 30px;">
        <div style="font-size: 0.75rem; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 15px;">
            Mã QR Gọi món
        </div>
        <h4 id="qr-table-label" style="font-weight: 900; font-size: 1.25rem; margin: 0 0 20px; color: var(--text-main);">--</h4>

        <div id="qr-container" style="display: flex; justify-content: center; margin-bottom: 20px; padding: 10px; background: white; border-radius: 12px; border: 1px solid #f0f0f0;">
            <!-- QR render -->
        </div>

        <p id="qr-no-token" style="display:none; font-size:0.85rem; color:#f43f5e; font-weight: 600; margin-bottom: 15px;">
            Chưa cấu hình mã QR cho bàn này.
        </p>

        <p id="qr-url-label" style="font-size: 0.7rem; color: #cbd5e1; word-break: break-all; margin-bottom: 20px; font-family: monospace;"></p>

        <button id="btn-download-qr" onclick="downloadQr()"
                style="display:none; width:100%; background: #f4f7fe; color: #2b3674; border: 1px solid #e2e8f0; padding: 12px; border-radius: 12px; font-weight: 800; font-size: 0.85rem; cursor: pointer; transition: all 0.2s;">
            <i class="fa-solid fa-download"></i> Tải ảnh QR (PNG)
        </button>
    </div>

</div>

<style>
    .order-item-card {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 20px;
        border-radius: 16px;
        background: #f8fafc;
        border: 1px solid transparent;
        transition: all 0.2s;
    }
    .order-item-card:hover { background: white; border-color: #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); }

    .item-qty {
        font-weight: 900;
        font-size: 1.25rem;
        color: var(--primary);
        min-width: 45px;
        text-align: center;
    }

    .item-info { flex-grow: 1; }
    .item-name { font-weight: 800; font-size: 1rem; color: var(--text-main); margin-bottom: 4px; }
    .item-note { font-size: 0.8rem; color: #f43f5e; font-weight: 600; display: flex; align-items: center; gap: 5px; }

    .item-status {
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        padding: 6px 12px;
        border-radius: 50px;
        letter-spacing: 0.5px;
    }

    .status-pending { background: #fef3c7; color: #92400e; }
    .status-preparing { background: #dbeafe; color: #1e40af; }
    .status-ready { background: #dcfce7; color: #166534; }
    .status-served { background: #f1f5f9; color: #64748b; }

    .btn-serve {
        background: #10b981;
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 10px;
        font-weight: 800;
        font-size: 0.8rem;
        cursor: pointer;
        box-shadow: 0 4px 0 #059669;
        transition: all 0.1s;
    }
    .btn-serve:active { transform: translateY(2px); box-shadow: 0 2px 0 #059669; }

    @@media (max-width: 1024px) {
        div[style*="grid-template-columns"] {
            grid-template-columns: 1fr !important;
        }
    }
</style>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

    <script>
        const urlParams = new URLSearchParams(window.location.search);
        const tableId = urlParams.get('tableId');
        const qrToken = urlParams.get('qrToken');
        const tableNumber = urlParams.get('tableNumber');
        let currentOrder = null;
        let storeConfig = null;

        // Load store config for tax
        async function loadStoreConfig() {
            try {
                storeConfig = await apiClient.getStoreConfig();
            } catch (e) { console.error('Lỗi tải config', e); }
        }

        function loadTableQr() {
            document.getElementById('qr-table-label').innerText = `Bàn ${tableNumber || '--'}`;

            if (!qrToken) {
                document.getElementById('qr-no-token').style.display = 'block';
                return;
            }

            const orderUrl = `${window.location.origin}/?token=${qrToken}`;
            document.getElementById('qr-url-label').innerText = orderUrl;

            const container = document.getElementById('qr-container');
            container.innerHTML = '';
            new QRCode(container, {
                text: orderUrl,
                width: 180,
                height: 180,
                colorDark: '#1a1a2e',
                colorLight: '#ffffff',
                correctLevel: QRCode.CorrectLevel.H
            });

            document.getElementById('btn-download-qr').style.display = 'block';
        }

        function downloadQr() {
            const canvas = document.querySelector('#qr-container canvas');
            if (!canvas) return;
            const link = document.createElement('a');
            link.download = `QR_FoodQR_Ban_${tableNumber}.png`;
            link.href = canvas.toDataURL('image/png');
            link.click();
        }

        async function loadOrder() {
            try {
                const order = await apiClient.getActiveOrder(tableId);
                if (!order) {
                    document.getElementById('items-list').innerHTML =
                        '<div style="text-align:center; padding: 60px; color: #94a3b8;"><i class="fa-solid fa-mug-hot fa-3x" style="margin-bottom:20px; opacity:0.3"></i><p style="font-weight:700">Hiện không có đơn hàng nào cho bàn này.</p></div>';
                    document.getElementById('order-total-container').style.display = 'none';
                    return;
                }
                document.getElementById('order-total-container').style.display = 'block';
                currentOrder = order;
                renderOrder(order);
            } catch (err) { console.error(err); }
        }

        function calculateBill(order) {
            const preDiscountTotal = (order.items || []).reduce((acc, i) => acc + (i.unitPrice * i.quantity), 0);
            const subtotal = order.totalAmount || 0;
            const discountAmount = preDiscountTotal > subtotal ? (preDiscountTotal - subtotal) : 0;
            
            const taxRate = storeConfig?.taxRate || 0.08;
            const isTaxIncluded = storeConfig?.isTaxIncludedInPrice || false;
            let taxAmount, total;

            if (isTaxIncluded) {
                taxAmount = Math.round(subtotal - (subtotal / (1 + taxRate)));
                total = subtotal;
            } else {
                taxAmount = Math.round(subtotal * taxRate);
                total = subtotal + taxAmount;
            }
            return { preDiscountTotal, discountAmount, subtotal, taxRate, taxAmount, total, isTaxIncluded };
        }

        function renderOrder(order) {
            document.getElementById('order-id').innerText = order.orderCode || order.id;
            
            let statusVN = order.status;
            if (statusVN.toLowerCase() === 'pending') statusVN = "Đang chờ";
            if (statusVN.toLowerCase() === 'paid') statusVN = "Đã thanh toán";
            
            document.getElementById('order-status').innerText = statusVN;

            const paymentStatusDiv = document.getElementById('payment-status');
            const sts = order.status.toLowerCase();
            if (sts !== 'paid' && sts !== 'completed' && sts !== 'cancelled') {
                paymentStatusDiv.innerHTML = `
                    <div style="display: flex; gap: 10px;">
                        <button onclick="showBillPopup('cash')" style="background: #10b981; color: white; border: none; padding: 12px 20px; border-radius: 12px; font-weight: 800; cursor: pointer; font-size: 0.9rem; box-shadow: 0 4px 0 #059669; display: flex; align-items: center; gap: 6px;">
                            <i class="fa-solid fa-money-bill-wave"></i> Tiền mặt
                        </button>
                        <button onclick="showBillPopup('vnpay')" style="background: #2563eb; color: white; border: none; padding: 12px 20px; border-radius: 12px; font-weight: 800; cursor: pointer; font-size: 0.9rem; box-shadow: 0 4px 0 #1d4ed8; display: flex; align-items: center; gap: 6px;">
                            <i class="fa-solid fa-qrcode"></i> Chuyển khoản
                        </button>
                        <button onclick="showMergeOptions()" style="background: #f59e0b; color: white; border: none; padding: 12px 20px; border-radius: 12px; font-weight: 800; cursor: pointer; font-size: 0.9rem; box-shadow: 0 4px 0 #d97706; display: flex; align-items: center; gap: 6px;">
                            <i class="fa-solid fa-object-group"></i> Gộp đơn
                        </button>
                    </div>`;
            } else {
                paymentStatusDiv.innerHTML = `<span style="background: #dcfce7; color: #166534; padding: 8px 20px; border-radius: 50px; font-size: 0.9rem; font-weight: 800; text-transform: uppercase;"><i class="fa-solid fa-check-circle"></i> Đã thanh toán</span>`;
            }

            const list = document.getElementById('items-list');
            list.innerHTML = order.items.map(i => {
                const itemSts = i.status.toLowerCase();
                let itemStsVN = i.status;
                if (itemSts === 'pending') itemStsVN = "Chờ chế biến";
                if (itemSts === 'preparing') itemStsVN = "Đang nấu";
                if (itemSts === 'ready') itemStsVN = "Đã xong";
                if (itemSts === 'served') itemStsVN = "Đã phục vụ";

                return `
                    <div class="order-item-card">
                        <div class="item-qty">x${i.quantity}</div>
                        <div class="item-info">
                            <div class="item-name">${i.name}</div>
                            ${i.note ? `<div class="item-note"><i class="fa-solid fa-comment-dots"></i> ${i.note}</div>` : ''}
                        </div>
                        <div class="item-status status-${itemSts}">${itemStsVN}</div>
                        ${itemSts === 'ready' ? `
                            <button class="btn-serve" onclick="serveItem(${i.id})">GIAO MÓN</button>
                        ` : ''}
                    </div>
                `;
            }).join('');

            // Show batch serve button if multiple items are ready
            const readyItems = order.items.filter(i => i.status.toLowerCase() === 'ready');
            const batchBar = document.getElementById('batch-serve-bar');
            if (readyItems.length > 1) {
                batchBar.style.display = 'block';
                document.getElementById('btn-serve-all').setAttribute('data-ids', JSON.stringify(readyItems.map(i => i.id)));
            } else {
                batchBar.style.display = 'none';
            }

            document.getElementById('order-total').innerText =
                (order.totalAmount || 0).toLocaleString('vi-VN') + ' ₫';
        }

        function showBillPopup(paymentMethod) {
            if (!currentOrder) return;
            const bill = calculateBill(currentOrder);
            const storeName = storeConfig?.storeName || 'FoodQR Restaurant';

            let itemsHtml = currentOrder.items.map(i => `
                <tr>
                    <td style="padding: 8px 0; font-size: 0.85rem; color: #334155;">${i.name}</td>
                    <td style="padding: 8px 0; text-align: center; font-weight: 700; color: #64748b; font-size: 0.85rem;">${i.quantity}</td>
                    <td style="padding: 8px 0; text-align: right; font-weight: 700; font-size: 0.85rem;">${(i.unitPrice * i.quantity).toLocaleString('vi-VN')} ₫</td>
                </tr>
            `).join('');

            const billHtml = `
                <div style="text-align: center; margin-bottom: 20px;">
                    <h3 style="font-weight: 900; font-size: 1.1rem; margin: 0;">${storeName}</h3>
                    <p style="color: #94a3b8; font-size: 0.75rem; margin: 4px 0 0;">HÓA ĐƠN THANH TOÁN</p>
                </div>
                <div style="border-top: 2px dashed #e2e8f0; border-bottom: 2px dashed #e2e8f0; padding: 5px 0; margin-bottom: 15px;">
                    <div style="display: flex; justify-content: space-between; font-size: 0.8rem; color: #64748b; font-weight: 600; padding: 5px 0;">
                        <span>Đơn: #${currentOrder.orderCode}</span>
                        <span>Bàn ${tableNumber || currentOrder.tableId}</span>
                    </div>
                </div>
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="border-bottom: 1px solid #f1f5f9;">
                            <th style="text-align: left; padding: 8px 0; font-size: 0.75rem; color: #94a3b8; font-weight: 700;">MÓN</th>
                            <th style="text-align: center; padding: 8px 0; font-size: 0.75rem; color: #94a3b8; font-weight: 700;">SL</th>
                            <th style="text-align: right; padding: 8px 0; font-size: 0.75rem; color: #94a3b8; font-weight: 700;">THÀNH TIỀN</th>
                        </tr>
                    </thead>
                    <tbody>${itemsHtml}</tbody>
                </table>
                <div style="border-top: 2px dashed #e2e8f0; margin-top: 10px; padding-top: 12px;">
                    ${bill.discountAmount > 0 ? `
                        <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                            <span style="color: #64748b; font-size: 0.85rem; font-weight: 600;">Tổng tiền món</span>
                            <span style="font-weight: 700; font-size: 0.85rem;">${bill.preDiscountTotal.toLocaleString('vi-VN')} ₫</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                            <span style="color: #10b981; font-size: 0.85rem; font-weight: 800;"><i class="fa-solid fa-tag"></i> Giảm giá</span>
                            <span style="font-weight: 800; font-size: 0.85rem; color: #10b981;">-${bill.discountAmount.toLocaleString('vi-VN')} ₫</span>
                        </div>
                    ` : ''}
                    <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                        <span style="color: #64748b; font-size: 0.85rem; font-weight: 600;">Tạm tính</span>
                        <span style="font-weight: 700; font-size: 0.85rem;">${bill.subtotal.toLocaleString('vi-VN')} ₫</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                        <span style="color: #64748b; font-size: 0.85rem; font-weight: 600;">Thuế VAT (${(bill.taxRate * 100).toFixed(0)}%)${bill.isTaxIncluded ? ' (đã gồm)' : ''}</span>
                        <span style="font-weight: 700; font-size: 0.85rem; color: #f59e0b;">${bill.isTaxIncluded ? '—' : '+' + bill.taxAmount.toLocaleString('vi-VN') + ' ₫'}</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; padding-top: 10px; border-top: 2px solid #1e293b;">
                        <span style="font-weight: 900; font-size: 1.1rem;">TỔNG CỘNG</span>
                        <span style="font-weight: 900; font-size: 1.3rem; color: var(--primary);">${bill.total.toLocaleString('vi-VN')} ₫</span>
                    </div>
                </div>
                <div id="vnpay-qr-section" style="display: none; margin-top: 20px;"></div>
            `;

            if (paymentMethod === 'cash') {
                Swal.fire({
                    title: '',
                    html: billHtml,
                    width: 420,
                    showCancelButton: true,
                    confirmButtonColor: '#10b981',
                    confirmButtonText: '<i class="fa-solid fa-check"></i> Đã nhận tiền mặt',
                    cancelButtonText: 'Hủy',
                    customClass: { popup: 'bill-popup' }
                }).then(async (result) => {
                    if (result.isConfirmed) {
                        try {
                            const res = await apiClient.checkoutCash(currentOrder.id);
                            if (res && res.ok) {
                                Swal.fire({ icon: 'success', title: 'Thành công', text: 'Đã thanh toán đơn hàng.', timer: 2000 });
                                loadOrder();
                            } else {
                                const err = await res.json();
                                Swal.fire('Lỗi', err.Error || 'Không thể thanh toán.', 'error');
                            }
                        } catch(e) {
                            Swal.fire('Lỗi', 'Có lỗi kết nối.', 'error');
                        }
                    }
                });
            } else {
                // VNPay
                Swal.fire({
                    title: '',
                    html: billHtml + `
                        <div style="text-align: center; margin-top: 20px;">
                            <div id="vnpay-loading" style="padding: 20px;">
                                <i class="fa-solid fa-spinner fa-spin" style="font-size: 2rem; color: #2563eb;"></i>
                                <p style="color: #64748b; font-size: 0.85rem; margin-top: 10px; font-weight: 600;">Đang tạo mã thanh toán...</p>
                            </div>
                            <div id="vnpay-qr-result" style="display: none;">
                                <div style="background: #eff6ff; border-radius: 12px; padding: 15px; margin-bottom: 15px;">
                                    <p style="font-size: 0.8rem; color: #1e40af; font-weight: 700; margin: 0 0 10px;">Quét mã QR để thanh toán qua VNPay</p>
                                    <div id="bill-qr-code" style="display: flex; justify-content: center; padding: 10px; background: white; border-radius: 10px;"></div>
                                </div>
                                <a id="vnpay-link" href="#" target="_blank" style="display: inline-block; background: #2563eb; color: white; padding: 10px 25px; border-radius: 10px; text-decoration: none; font-weight: 800; font-size: 0.85rem;">
                                    <i class="fa-solid fa-external-link-alt"></i> Mở trang thanh toán
                                </a>
                            </div>
                        </div>
                    `,
                    width: 440,
                    showConfirmButton: false,
                    showCancelButton: true,
                    cancelButtonText: 'Đóng',
                    didOpen: () => createVnPayQr()
                });
            }
        }

        async function createVnPayQr() {
            try {
                const res = await apiClient.createVnPayUrl(currentOrder.id);
                if (!res || !res.ok) {
                    const err = await res?.json();
                    document.getElementById('vnpay-loading').innerHTML = `<p style="color: #dc2626; font-weight: 700;"><i class="fa-solid fa-xmark-circle"></i> ${err?.Error || 'Lỗi tạo mã'}</p>`;
                    return;
                }
                const data = await res.json();
                document.getElementById('vnpay-loading').style.display = 'none';
                document.getElementById('vnpay-qr-result').style.display = 'block';
                document.getElementById('vnpay-link').href = data.paymentUrl;

                new QRCode(document.getElementById('bill-qr-code'), {
                    text: data.paymentUrl,
                    width: 200,
                    height: 200,
                    colorDark: '#1e40af',
                    colorLight: '#ffffff',
                    correctLevel: QRCode.CorrectLevel.M
                });
            } catch (e) {
                document.getElementById('vnpay-loading').innerHTML = '<p style="color: #dc2626; font-weight: 700;">Lỗi kết nối</p>';
            }
        }

        async function serveItem(itemId) {
            const res = await apiClient.updateItemStatus(itemId, 'served');
            if (res && res.ok) loadOrder();
        }

        async function serveAll() {
            const btn = document.getElementById('btn-serve-all');
            const ids = JSON.parse(btn.getAttribute('data-ids') || '[]');
            if (!ids.length) return;
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang giao...';
            for (const id of ids) {
                await apiClient.updateItemStatus(id, 'served');
            }
            loadOrder();
        }

        async function showMergeOptions() {
            try {
                Swal.showLoading();
                const res = await fetch(`${apiBase}/Tables`, {
                    headers: { 'Authorization': `Bearer ${localStorage.getItem('auth_token')}` }
                });
                const tables = await res.json();
                
                const activeTables = tables.filter(t => t.status.toLowerCase() === 'taken' && t.id != tableId);
                
                if (activeTables.length === 0) {
                    Swal.fire('Thông báo', 'Không có bàn nào khác đang hoạt động để gộp.', 'info');
                    return;
                }

                let optionsHtml = activeTables.map(t => `<option value="${t.id}">Bàn ${t.tableNumber}</option>`).join('');
                Swal.close();
                
                const { value: sourceTableId, isConfirmed } = await Swal.fire({
                    title: 'Gộp đơn từ bàn khác',
                    html: `
                        <p style="font-size: 0.9rem; color: #64748b; margin-bottom: 10px;">Chọn bàn muốn gộp hóa đơn <b>vào bàn này</b> (Bàn ${tableNumber}). Bàn được chọn sẽ trở thành bàn trống.</p>
                        <select id="swal-merge-table" class="swal2-input" style="width:100%">
                            ${optionsHtml}
                        </select>
                    `,
                    showCancelButton: true,
                    confirmButtonColor: '#f59e0b',
                    confirmButtonText: 'Gộp hóa đơn',
                    cancelButtonText: 'Hủy',
                    preConfirm: () => {
                        return document.getElementById('swal-merge-table').value;
                    }
                });

                if (isConfirmed && sourceTableId) {
                    // Get active order of source table to get sourceOrderId
                    Swal.showLoading();
                    const sRes = await fetch(`${apiBase}/Orders/active/${sourceTableId}`, {
                        headers: { 'Authorization': `Bearer ${localStorage.getItem('auth_token')}` }
                    });
                    if (!sRes.ok) {
                        Swal.fire('Lỗi', 'Bàn được chọn không có đơn hàng hợp lệ để gộp.', 'error');
                        return;
                    }
                    const sourceOrder = await sRes.json();
                    
                    const mergeRes = await apiClient.mergeOrder(currentOrder.id, sourceOrder.id);
                    if (mergeRes && mergeRes.ok) {
                        Swal.fire('Thành công', 'Đã gộp đơn hàng. Các món ăn đã được chuyển sang bàn này.', 'success');
                        loadOrder();
                    } else {
                        const err = await mergeRes.json();
                        Swal.fire('Lỗi', err.Error || 'Không thể gộp.', 'error');
                    }
                }
            } catch (e) {
                console.error("Lỗi Gộp Bill Detailed:", e);
                const errText = e.Error || e.error || e.message || (e.errors ? JSON.stringify(e.errors) : JSON.stringify(e));
                Swal.fire('Lỗi Gộp Bill', errText || 'Có lỗi xảy ra khi gộp bill.', 'error');
            }
        }

        loadStoreConfig();
        loadTableQr();
        loadOrder();
        setInterval(loadOrder, 10000); // Polling update
    </script>
}

