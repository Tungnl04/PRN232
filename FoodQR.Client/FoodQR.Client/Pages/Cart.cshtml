@page
@model CartModel
@{
    ViewData["Title"] = "Your Cart";
}

<div class="container animate-in">
    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
        <a id="back-link" href="/" style="color: var(--text); font-size: 1.2rem;"><i class="fa-solid fa-arrow-left"></i></a>
        <h2 class="font-bold">Your Cart</h2>
    </div>

    <div id="token-loading" style="text-align:center; padding: 40px; display:none;">
        <i class="fa-solid fa-circle-notch fa-spin" style="font-size:2rem; color:var(--primary);"></i>
        <p style="color:var(--text-muted); margin-top:12px;">Đang xác thực bàn...</p>
    </div>

    <div id="token-error" style="display:none; text-align:center; padding:40px;">
        <i class="fa-solid fa-triangle-exclamation" style="font-size:3rem; color:#ff4d4d; margin-bottom:16px;"></i>
        <p style="font-weight:700; font-size:1.1rem;">QR Code không hợp lệ</p>
        <p style="color:var(--text-muted); margin-top:8px;">Vui lòng quét lại mã QR trên bàn của bạn.</p>
    </div>

    <div id="cart-content" style="display:none;">
        <div id="cart-items-list"></div>

        <div id="empty-cart" style="display: none; text-align: center; padding: 40px;">
            <i class="fa-solid fa-cart-shopping" style="font-size: 3rem; color: #eee; margin-bottom: 16px;"></i>
            <p style="color: var(--text-muted);">Your cart is empty.</p>
            <a id="empty-back-link" href="/" class="mt-4" style="display: inline-block; background: var(--primary); color: white; padding: 10px 20px; border-radius: var(--radius-sm); text-decoration: none;">
                Go back to menu
            </a>
        </div>

        <div id="cart-footer" style="margin-top: 32px; display: none;">
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 16px 0; border-top: 2px dashed #eee;">
                <span class="font-bold">Total Amount</span>
                <span id="total-price" style="font-size: 1.2rem; font-weight: 800; color: var(--primary);">0đ</span>
            </div>

            <div class="card mt-4">
                <h3 class="font-bold" style="margin-bottom: 16px; font-size: 1rem;">Checkout Information</h3>
                <div style="display: flex; flex-direction: column; gap: 12px;">
                    <div>
                        <label style="font-size: 0.8rem; font-weight: 600; color: var(--text-muted); display: block; margin-bottom: 4px;">Name (Required)</label>
                        <input type="text" id="customer-name" placeholder="Enter your name"
                               style="width: 100%; padding: 12px; border-radius: var(--radius-sm); border: 1px solid #ddd; font-family: inherit;" required />
                    </div>
                    <div>
                        <label style="font-size: 0.8rem; font-weight: 600; color: var(--text-muted); display: block; margin-bottom: 4px;">Email (Optional)</label>
                        <input type="email" id="customer-email" placeholder="example@gmail.com"
                               style="width: 100%; padding: 12px; border-radius: var(--radius-sm); border: 1px solid #ddd; font-family: inherit;" />
                    </div>
                </div>
            </div>

            <button onclick="submitOrder()" id="btn-submit"
                    style="width: 100%; padding: 16px; background: var(--primary); color: white; border: none; border-radius: var(--radius-md); font-weight: 700; font-size: 1rem; margin-top: 24px; cursor: pointer; transition: var(--transition);">
                Confirm Order
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const apiBaseUrl = "@(ViewData["ApiBaseUrl"] ?? "https://localhost:7197/api")";

        let tableId = @Model.TableId;

        async function resolveTable() {
            const params = new URLSearchParams(window.location.search);
            const token = params.get('token');

            if (token) {
                document.getElementById('token-loading').style.display = 'block';
                try {
                    const res = await fetch(`${apiBaseUrl}/Tables/by-token/${encodeURIComponent(token)}`);
                    if (!res.ok) throw new Error('invalid token');

                    const tableData = await res.json();
                    tableId = tableData.id;

                    document.getElementById('token-loading').style.display = 'none';
                    initCart();
                } catch {
                    document.getElementById('token-loading').style.display = 'none';
                    document.getElementById('token-error').style.display = 'block';
                }
            } else if (tableId > 0) {
                initCart();
            } else {
                document.getElementById('token-error').style.display = 'block';
            }
        }

        function initCart() {
            const params = new URLSearchParams(window.location.search);
            const token = params.get('token');
            const menuUrl = token ? `/?token=${token}` : `/?tableId=${tableId}`;
            document.getElementById('back-link').href = menuUrl;
            document.getElementById('empty-back-link').href = menuUrl;

            const tableDisplay = document.getElementById('current-table');
            if (tableDisplay) tableDisplay.innerText = tableId > 0 ? tableId : '??';

            document.getElementById('cart-content').style.display = 'block';

            fetchActiveOrder();
            renderCart();
        }

        async function fetchActiveOrder() {
            if (tableId <= 0) return;
            try {
                const res = await fetch(`${apiBaseUrl}/Orders/active/${tableId}`);
                if (!res.ok) return;

                const activeOrder = await res.json();
                const nameInput  = document.getElementById('customer-name');
                const emailInput = document.getElementById('customer-email');
                const heading    = document.querySelector('#cart-content .card h3');

                if (heading) heading.innerText = 'Gộp thêm món vào đơn hiện tại';

                if (activeOrder.customerName) {
                    nameInput.value  = activeOrder.customerName;
                    emailInput.value = activeOrder.customerEmail || '';
                } else {
                    nameInput.value = 'Khách cũ bàn ' + tableId;
                }

                nameInput.readOnly  = true;
                emailInput.readOnly = true;
                nameInput.style.backgroundColor  = '#f5f5f5';
                emailInput.style.backgroundColor = '#f5f5f5';
            } catch (e) {
                console.error('Lỗi khi fetch active order', e);
            }
        }

        let cart = JSON.parse(localStorage.getItem('food_cart')) || [];

        function renderCart() {
            const list   = document.getElementById('cart-items-list');
            const footer = document.getElementById('cart-footer');
            const empty  = document.getElementById('empty-cart');

            if (cart.length === 0) {
                list.innerHTML = '';
                footer.style.display = 'none';
                empty.style.display  = 'block';
                return;
            }

            empty.style.display  = 'none';
            footer.style.display = 'block';

            let total = 0;
            list.innerHTML = cart.map((item, index) => {
                total += item.price * item.quantity;
                return `
                    <div class="card" style="margin-bottom: 12px; display: flex; align-items: center; gap: 12px;">
                        <img src="${item.imageUrl}" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;"
                            onerror="this.onerror=null;this.src='https://placehold.co/100x100?text=Food';" />
                        <div style="flex-grow: 1;">
                            <h4 style="font-size: 0.9rem; font-weight: 700;">${item.name}</h4>
                            <span style="font-size: 0.8rem; color: var(--primary); font-weight: bold;">${(item.price).toLocaleString('vi-VN')}đ</span>
                        </div>
                        <div style="display: flex; align-items: center; gap: 10px; background: #f3f3f3; padding: 4px 10px; border-radius: 20px;">
                            <i class="fa-solid fa-minus" onclick="updateQty(${index}, -1)" style="font-size: 0.7rem; cursor: pointer;"></i>
                            <span style="font-size: 0.9rem; font-weight: bold; min-width: 20px; text-align: center;">${item.quantity}</span>
                            <i class="fa-solid fa-plus"  onclick="updateQty(${index},  1)" style="font-size: 0.7rem; cursor: pointer;"></i>
                        </div>
                    </div>
                `;
            }).join('');

            document.getElementById('total-price').innerText = total.toLocaleString('vi-VN') + 'đ';
        }

        function updateQty(index, delta) {
            cart[index].quantity += delta;
            if (cart[index].quantity <= 0) cart.splice(index, 1);
            localStorage.setItem('food_cart', JSON.stringify(cart));
            renderCart();

            const badge = document.getElementById('cart-count');
            if (badge) {
                const count = cart.reduce((sum, item) => sum + item.quantity, 0);
                badge.innerText = count;
                badge.style.display = count > 0 ? 'flex' : 'none';
            }
        }

        async function submitOrder() {
            const name  = document.getElementById('customer-name').value;
            const email = document.getElementById('customer-email').value;

            if (!name) {
                Swal.fire({ icon: 'error', text: 'Please enter your name!' });
                return;
            }

            Swal.fire({ title: 'Confirming Order...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });

            const params = new URLSearchParams(window.location.search);
            const token = params.get('token');

            const orderData = {
                customerName:  name,
                customerEmail: email,
                tableId:       tableId,
                token:         token,
                items: cart.map(item => ({
                    productId: item.isCombo ? null : item.id,
                    comboId:   item.isCombo ? item.id : null,
                    quantity:  item.quantity
                }))
            };

            try {
                const response = await fetch(`${apiBaseUrl}/Orders`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(orderData)
                });

                if (response.ok) {
                    const result = await response.json();
                    localStorage.setItem('food_active_order_id', result.id);
                    localStorage.removeItem('food_cart');
                    window.location.href = `/OrderSuccess?orderId=${result.id}&tableId=${tableId}&orderCode=${result.orderCode}${token ? '&token=' + token : ''}`;
                } else {
                    throw new Error('Failed');
                }
            } catch {
                Swal.fire({ icon: 'error', text: 'Something went wrong. Please try again.' });
            }
        }

        window.addEventListener('DOMContentLoaded', resolveTable);
    </script>
}
