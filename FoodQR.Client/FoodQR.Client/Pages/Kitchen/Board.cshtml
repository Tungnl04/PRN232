@page
@model FoodQR.Client.Pages.Kitchen.BoardModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Điều phối Bếp";
}

<link rel="stylesheet" href="~/css/kitchen/board.css" asp-append-version="true" />

<div class="kanban-container">
    <!-- ĐANG CHỜ -->
    <div class="kanban-column" id="col-pending">
        <div class="column-header">
            <div class="column-title">
                <i class="fa-solid fa-clock"></i>
                <span>Đang chờ</span>
            </div>
            <span class="column-count" id="count-pending">0</span>
        </div>
        <div class="kanban-list"></div>
    </div>

    <!-- ĐANG LÀM -->
    <div class="kanban-column" id="col-preparing">
        <div class="column-header">
            <div class="column-title">
                <i class="fa-solid fa-fire-burner"></i>
                <span>Đang làm</span>
            </div>
            <span class="column-count" id="count-preparing">0</span>
        </div>
        <div class="kanban-list"></div>
    </div>

    <!-- HOÀN TẤT -->
    <div class="kanban-column" id="col-ready">
        <div class="column-header">
            <div class="column-title">
                <i class="fa-solid fa-check-double"></i>
                <span>Hoàn tất</span>
            </div>
            <span class="column-count" id="count-ready">0</span>
        </div>
        <div class="kanban-list"></div>
    </div>
</div>

@section Scripts {
    <script>
        // Override global function if needed or listen to it
        window.onNewOrder = () => loadKitchenItems();

        async function loadKitchenItems() {
            try {
                const items = await apiClient.getKitchenItems();
                renderItems(items);
            } catch (err) { console.error(err); }
        }

        function renderItems(items) {
            const cols = {
                'pending': document.querySelector('#col-pending .kanban-list'),
                'preparing': document.querySelector('#col-preparing .kanban-list'),
                'ready': document.querySelector('#col-ready .kanban-list')
            };

            Object.values(cols).forEach(c => c.innerHTML = '');
            let counts = { pending: 0, preparing: 0, ready: 0 };

            items.forEach(item => {
                const status = item.status.toLowerCase();
                if (!cols[status]) return;
                counts[status]++;
                
                const card = document.createElement('div');
                card.className = `kitchen-card`;
                card.innerHTML = `
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px;">
                        <span class="table-badge">BÀN ${item.tableNumber || '?'}</span>
                        <span class="order-code">${item.orderCode.substring(0,8)}</span>
                    </div>
                    
                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                        <div style="flex: 1; padding-right: 15px;">
                            <div class="dish-name">${item.dishName}</div>
                            ${item.note ? `<div class="dish-note"><i class="fa-solid fa-comment-dots"></i> ${item.note}</div>` : ''}
                        </div>
                        <div class="dish-qty">x${item.quantity}</div>
                    </div>

                    <div class="dish-meta">
                         ${status === 'pending' ? `<button class="btn-action primary" onclick="updateItem(${item.id}, 'preparing')"><i class="fa-solid fa-play"></i> CHẾ BIẾN</button>` : ''}
                         ${status === 'preparing' ? `<button class="btn-action primary" style="background:#3b82f6" onclick="updateItem(${item.id}, 'ready')"><i class="fa-solid fa-check"></i> XONG</button>` : ''}
                         ${status === 'ready' ? `<div style="text-align:center; width:100%; color:#94a3b8; font-size:0.8rem; font-weight:600; font-style:italic;">Chờ bưng món...</div>` : ''}
                    </div>
                `;
                cols[status].appendChild(card);
            });

            document.getElementById('count-pending').innerText = counts.pending;
            document.getElementById('count-preparing').innerText = counts.preparing;
            document.getElementById('count-ready').innerText = counts.ready;
        }

        async function updateItem(itemId, newStatus) {
            try {
                const res = await apiClient.updateItemStatus(itemId, newStatus);
                if (res && res.ok) {
                    loadKitchenItems();
                }
            } catch (err) { console.error(err); }
        }

        loadKitchenItems();
        setInterval(loadKitchenItems, 10000);
    </script>
}
