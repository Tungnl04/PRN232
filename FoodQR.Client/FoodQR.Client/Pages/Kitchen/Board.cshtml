@page
@model FoodQR.Client.Pages.Kitchen.BoardModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Điều phối Bếp";
}

<link rel="stylesheet" href="~/css/kitchen/board.css" asp-append-version="true" />

<div class="kanban-container">
    <!-- ĐANG CHỜ -->
    <div class="kanban-column" id="col-pending">
        <div class="column-header">
            <div class="column-title">
                <i class="fa-solid fa-clock"></i>
                <span>Đang chờ</span>
            </div>
            <span class="column-count" id="count-pending">0</span>
        </div>
        <div class="kanban-list"></div>
    </div>

    <!-- ĐANG LÀM -->
    <div class="kanban-column" id="col-preparing">
        <div class="column-header">
            <div class="column-title">
                <i class="fa-solid fa-fire-burner"></i>
                <span>Đang làm</span>
            </div>
            <span class="column-count" id="count-preparing">0</span>
        </div>
        <div class="kanban-list"></div>
    </div>

    <!-- HOÀN TẤT -->
    <div class="kanban-column" id="col-ready">
        <div class="column-header">
            <div class="column-title">
                <i class="fa-solid fa-check-double"></i>
                <span>Hoàn tất</span>
            </div>
            <span class="column-count" id="count-ready">0</span>
        </div>
        <div class="kanban-list"></div>
    </div>
</div>

@section Scripts {
    <script>
        window.onNewOrder = () => loadKitchenItems();

        async function loadKitchenItems() {
            try {
                const items = await apiClient.getKitchenItems();
                renderItems(items);
            } catch (err) { console.error(err); }
        }

        function groupByTable(items) {
            const groups = {};
            items.forEach(item => {
                const key = `${item.orderCode}`;
                if (!groups[key]) {
                    groups[key] = {
                        orderCode: item.orderCode,
                        tableNumber: item.tableNumber,
                        items: []
                    };
                }
                groups[key].items.push(item);
            });
            return Object.values(groups);
        }

        function renderItems(items) {
            const cols = {
                'pending': document.querySelector('#col-pending .kanban-list'),
                'preparing': document.querySelector('#col-preparing .kanban-list'),
                'ready': document.querySelector('#col-ready .kanban-list')
            };
            Object.values(cols).forEach(c => c.innerHTML = '');
            let counts = { pending: 0, preparing: 0, ready: 0 };

            // Count per status
            items.forEach(item => {
                const s = item.status.toLowerCase();
                if (counts[s] !== undefined) counts[s]++;
            });

            // Group items by status first, then by table
            ['pending', 'preparing', 'ready'].forEach(status => {
                const statusItems = items.filter(i => i.status.toLowerCase() === status);
                const groups = groupByTable(statusItems);

                groups.forEach(group => {
                    const card = document.createElement('div');
                    card.className = 'kitchen-card';

                    // --- Table Header ---
                    let headerHtml = `
                        <div class="table-group-header">
                            <div class="table-group-info">
                                <span class="table-badge">BÀN ${group.tableNumber || '?'}</span>
                                <span class="order-code">${group.orderCode.substring(0,8)}</span>
                                <span class="item-count-badge">${group.items.length} món</span>
                            </div>`;

                    // --- Batch Action Button (only if >1 item) ---
                    if (group.items.length > 1) {
                        if (status === 'pending') {
                            headerHtml += `<button class="btn-batch primary" onclick="batchUpdate('${group.orderCode}', 'pending', 'preparing')"><i class="fa-solid fa-forward"></i> Chế biến TẤT CẢ</button>`;
                        } else if (status === 'preparing') {
                            headerHtml += `<button class="btn-batch primary" style="background:#3b82f6" onclick="batchUpdate('${group.orderCode}', 'preparing', 'ready')"><i class="fa-solid fa-check-double"></i> Xong TẤT CẢ</button>`;
                        }
                    }
                    headerHtml += `</div>`;

                    // --- Item Rows ---
                    let itemsHtml = group.items.map(item => `
                        <div class="table-group-item">
                            <div class="item-info">
                                <span class="dish-name-sm">${item.dishName}</span>
                                ${item.note ? `<span class="dish-note-sm" title="${item.note}"><i class="fa-solid fa-comment-dots"></i> ${item.note}</span>` : ''}
                            </div>
                            <div class="item-actions">
                                <span class="dish-qty-sm">x${item.quantity}</span>
                                ${status === 'pending' ? `<button class="btn-item primary" onclick="updateItem(${item.id}, 'preparing')" title="Chế biến"><i class="fa-solid fa-play"></i></button>` : ''}
                                ${status === 'preparing' ? `<button class="btn-item primary" style="background:#3b82f6" onclick="updateItem(${item.id}, 'ready')" title="Xong"><i class="fa-solid fa-check"></i></button>` : ''}
                                ${status === 'ready' ? `<span class="status-done"><i class="fa-solid fa-clock"></i></span>` : ''}
                            </div>
                        </div>
                    `).join('');

                    card.innerHTML = headerHtml + `<div class="table-group-items">${itemsHtml}</div>`;
                    cols[status].appendChild(card);
                });
            });

            document.getElementById('count-pending').innerText = counts.pending;
            document.getElementById('count-preparing').innerText = counts.preparing;
            document.getElementById('count-ready').innerText = counts.ready;
        }

        async function updateItem(itemId, newStatus) {
            try {
                const res = await apiClient.updateItemStatus(itemId, newStatus);
                if (res && res.ok) loadKitchenItems();
            } catch (err) { console.error(err); }
        }

        async function batchUpdate(orderCode, fromStatus, toStatus) {
            try {
                const items = await apiClient.getKitchenItems();
                const targets = items.filter(i =>
                    i.orderCode === orderCode && i.status.toLowerCase() === fromStatus
                );
                if (!targets.length) return;

                // Gọi tuần tự để tránh race condition
                for (const item of targets) {
                    await apiClient.updateItemStatus(item.id, toStatus);
                }
                loadKitchenItems();
            } catch (err) { console.error(err); }
        }

        loadKitchenItems();
        setInterval(loadKitchenItems, 10000);
    </script>
}
