<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kitchen Monitor - FoodStore</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/management.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        /* Kitchen specific full screen overrides */
        .main-content { padding: 20px; }
        .top-bar { margin-bottom: 20px; }
        .kitchen-logo { color: var(--primary); font-weight: 800; font-size: 1.2rem; }
    </style>
</head>
<body class="mgmt-body">
    <div class="sidebar" style="width: 200px;">
        <div class="logo">
            <i class="fa-solid fa-fire-burner"></i>
            <span>KITCHEN</span>
        </div>
        <nav>
            <a href="/Kitchen/Board" class="nav-item active">
                <i class="fa-solid fa-list-check"></i>
                <span>Monitor</span>
            </a>
        </nav>
        <div style="margin-top: auto;">
            <a href="#" onclick="apiClient.logout()" class="nav-item" style="color: #ff4d4d;">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Logout</span>
            </a>
        </div>
    </div>

    <div class="main-content" style="margin-left: 200px;">
        <div class="top-bar">
            <h2 id="page-title" style="font-weight: 800; margin: 0;">Kitchen Monitor</h2>
            <div style="display: flex; align-items: center; gap: 20px;">
                <div style="font-size: 0.9rem; font-weight: 700; color: #666;"><i class="fa-solid fa-circle" style="color: #4caf50; font-size: 0.6rem;"></i> LIVE SYSTEM</div>
                <div class="user-profile">
                     <span style="font-weight: bold; font-size: 0.8rem;">Chef <span id="user-display-name">--</span></span>
                </div>
            </div>
        </div>
        @RenderBody()
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/apiClient.js" asp-append-version="true"></script>
    <script>
        if (!apiClient.isAuthenticated() || (apiClient.getUser().role !== 'kitchen' && apiClient.getUser().role !== 'admin')) {
            apiClient.logout();
        }
        document.getElementById('user-display-name').innerText = apiClient.getUser().name || 'Kitchen';

        // === SignalR Connection ===
        const kitchenConnection = new signalR.HubConnectionBuilder()
            .withUrl('https://localhost:7197/hubs/order')
            .withAutomaticReconnect()
            .build();

        kitchenConnection.on('NewOrderReceived', (data) => {
            console.log('📦 New order:', data);
            Swal.fire({
                icon: 'info',
                title: '🔔 Đơn mới!',
                text: `Bàn ${data.tableId} - Đơn ${data.orderCode}`,
                timer: 3000,
                showConfirmButton: false,
                position: 'top-end',
                toast: true
            });
            if (typeof loadKitchenItems === 'function') loadKitchenItems();
        });

        kitchenConnection.on('ItemStatusChanged', (data) => {
            console.log('🔄 Item changed:', data);
            if (typeof loadKitchenItems === 'function') loadKitchenItems();
        });

        kitchenConnection.start()
            .then(() => {
                console.log('✅ SignalR connected (Kitchen)');
                kitchenConnection.invoke('JoinGroup', 'kitchen');
            })
            .catch(err => console.error('SignalR Error:', err));
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
